#!/usr/bin/env bash
set -euo pipefail

VERSION="0.13.12"
DEFAULT_REPO_URL="https://github.com/bssm-oss/cmux4justn.git"
DEFAULT_ACTIVE_DIR="${HOME:-/Users/justn}/.c4j/active"
DEFAULT_ANCHOR_DIR="${HOME:-/Users/justn}/Workspaces"
DEFAULT_WORKTREE_DIR="${HOME:-/Users/justn}/Workspaces/worktrees"
CONFIG_FILE="${C4J_CONFIG:-${CMUX4JUSTN_CONFIG:-${HOME:-/Users/justn}/.c4j/config}}"

C4J_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
C4J_CONTRACT_FILE="$C4J_SCRIPT_DIR/../lib/c4j-contract.bash"
if [ -f "$C4J_CONTRACT_FILE" ]; then
  # shellcheck disable=SC1090,SC1091
  source "$C4J_CONTRACT_FILE"
fi
C4J_CONFIG_LIB_FILE="$C4J_SCRIPT_DIR/../lib/c4j-config.bash"
if [ -f "$C4J_CONFIG_LIB_FILE" ]; then
  # shellcheck disable=SC1090,SC1091
  source "$C4J_CONFIG_LIB_FILE"
fi
C4J_OUTPUT_LIB_FILE="$C4J_SCRIPT_DIR/../lib/c4j-output.bash"
if [ -f "$C4J_OUTPUT_LIB_FILE" ]; then
  # shellcheck disable=SC1090,SC1091
  source "$C4J_OUTPUT_LIB_FILE"
fi
: "${C4J_ACTION_CD_PROJECT:=cd-project}"
: "${C4J_ACTION_GO_PROJECT:=go-project}"
: "${C4J_ACTION_CREATE_WORKTREE:=create-worktree}"
: "${C4J_ACTION_REUSE_WORKTREE:=reuse-worktree}"
: "${C4J_ACTION_MOVE_WORKTREE:=move-worktree}"

if ! declare -F tsv_row >/dev/null 2>&1; then
  tsv_row() {
    local first="$1"
    shift
    printf '%s' "$first"
    local field
    for field in "$@"; do
      printf '\t%s' "$field"
    done
    printf '\n'
  }
fi

if ! declare -F config_get_value >/dev/null 2>&1; then
config_get_value() {
  local key="$1"
  [ -f "$CONFIG_FILE" ] || return 1
  awk -F '=' -v key="$key" '$1 == key { print substr($0, length(key) + 2); found = 1 } END { exit found ? 0 : 1 }' "$CONFIG_FILE"
}
fi

CONFIG_ACTIVE_DIR="$(config_get_value active_dir 2>/dev/null || true)"
CONFIG_CMUX_BIN="$(config_get_value cmux_bin 2>/dev/null || true)"
CONFIG_NAME_PREFIX="$(config_get_value name_prefix 2>/dev/null || true)"

ACTIVE_DIR="${C4J_ACTIVE_DIR:-${CMUX4JUSTN_ACTIVE_DIR:-${ACTIVE_DIR:-${CONFIG_ACTIVE_DIR:-$DEFAULT_ACTIVE_DIR}}}}"
CMUX_BIN="${C4J_CMUX_BIN:-${CMUX4JUSTN_CMUX_BIN:-${CMUX_BIN:-${CONFIG_CMUX_BIN:-}}}}"
NAME_PREFIX="${C4J_NAME_PREFIX:-${CMUX4JUSTN_NAME_PREFIX:-${CONFIG_NAME_PREFIX:-@active/}}}"
WORKTREE_DIR="${C4J_WORKTREE_DIR:-${CMUX4JUSTN_WORKTREE_DIR:-$DEFAULT_WORKTREE_DIR}}"

usage() {
  cat <<USAGE
c4j v$VERSION - project switcher for cmux

I want to:
  c4j go <project>      open a project and focus its cmux workspace
  c4j cd <project>      change directory to an active project
  c4j wt [name]         make a worktree for the current repo
  c4j list              show active projects
  c4j repair --apply    reconcile c4j and cmux

Set up or fix:
  c4j setup             use the normal @active/ setup
  c4j repair            preview c4j/cmux reconciliation
  c4j doctor            check what is broken
  c4j update            update c4j

More help:
  c4j help go
  c4j help cd
  c4j help wt
  c4j help repair
  c4j help agent
  c4j help config

Tip: add --dry-run before risky changes.
USAGE
}

command_help() {
  local topic="${1:-}"

  case "$topic" in
    ""|help)
      usage
      ;;
    add)
      cat <<'USAGE'
c4j add <folder>...

Add folders to c4j, then sync them to cmux.
With no folder, this previews a two-way sync.

Try:
  c4j add .
  c4j add --apply
  c4j add ~/Workspaces/repos/example
  c4j add --dry-run .

Notes:
  folder adds default to --apply
  no-folder add needs --apply to change anything
  --dry-run previews without changing anything
USAGE
      ;;
    cd)
      cat <<'USAGE'
c4j cd <project-or-folder>

Change directory to an active project by name, or to a directory path.
This does not touch cmux and does not add new active project links.

Try:
  c4j cd cmux4justn
  c4j cd .
  c4j cd --dry-run codeagora

Note:
  shell directory changes require the wrapper installed by scripts/install.sh --rc
USAGE
      ;;
    go)
      cat <<'USAGE'
c4j go <project-or-folder>

Open a project. You can pass an active project name or a folder path.
c4j also focuses the matching cmux workspace, or creates it if missing.

Try:
  c4j go cmux4justn
  c4j go .
  c4j go --no-cmux codeagora

Options:
  --dry-run   show what would happen
  --no-cmux   only manage the project link; do not touch cmux
USAGE
      ;;
    anchor)
      cat <<'USAGE'
c4j anchor

Create or repair the pinned cmux workspace for ~/Workspaces.
You usually only run this once.

Try:
  c4j anchor
  c4j anchor --dry-run
  c4j anchor --name justn-is-always-around-here --cwd ~/Workspaces
USAGE
      ;;
    delete|remove|rm)
      cat <<'USAGE'
c4j delete <project>...

Remove projects from c4j and close their matching cmux workspaces.

Try:
  c4j delete old-project
  c4j delete --dry-run old-project
  c4j delete --keep-cmux old-project

Options:
  --keep-cmux  remove the c4j link but leave the cmux workspace open
USAGE
      ;;
    setup)
      cat <<'USAGE'
c4j setup

Write the normal local defaults. This sets cmux workspace names to @active/*.

Try:
  c4j setup
  c4j setup --dry-run
  c4j setup --active-dir ~/.c4j/active
USAGE
      ;;
    sync)
      cat <<'USAGE'
c4j sync

Low-level sync command for scripts and advanced repair.
For normal human repair, use c4j repair.

Try:
  c4j sync
  c4j sync --apply
  c4j sync --direction both --apply

Directions:
  active-to-cmux  c4j list -> cmux workspaces
  cmux-to-active  cmux workspaces -> c4j list
  both            do both
USAGE
      ;;
    repair|reconcile)
      cat <<'USAGE'
c4j repair

Preview a two-way reconciliation between c4j active projects and cmux.
Use --apply only after the preview looks right.

Try:
  c4j repair
  c4j repair --apply
  c4j reconcile --dry-run

Notes:
  repair and reconcile are aliases
  script-level direction control stays available through c4j sync
USAGE
      ;;
    list|ls)
      cat <<'USAGE'
c4j list

Show projects c4j knows about.

Try:
  c4j list
  c4j list --plain

Option:
  --plain  print tab-separated rows for scripts
USAGE
      ;;
    config)
      cat <<'USAGE'
c4j config

Read or change c4j's local config.

Try:
  c4j config get
  c4j config set active-dir ~/.c4j/active
  c4j config set name-prefix @active/
  c4j config unset active-dir
  c4j config path
USAGE
      ;;
    agent|agents|script|scripts|automation|ax)
      cat <<USAGE
c4j help agent

For agents and scripts:

Use previews before changes:
  c4j sync --dry-run
  c4j delete --dry-run <project>
  c4j wt move --dry-run <worktree> <new-name>

Prefer plain output when reading lists:
  c4j list --plain
  c4j wt list --plain

Parse action rows by the first tab-separated field:
  $C4J_ACTION_CD_PROJECT       <name> <path>
  $C4J_ACTION_GO_PROJECT       <name> <path>
  $C4J_ACTION_CREATE_WORKTREE  <name> <path> <branch>
  $C4J_ACTION_REUSE_WORKTREE   <name> <path>
  summary          key=value ...

Conventions:
  --help and -h print help to stdout
  --version and version print only the version
  output is plain text: no colors, icons, spinners, or box drawing
  commands are non-interactive; use --apply or --dry-run explicitly
USAGE
      ;;
    doctor)
      cat <<'USAGE'
c4j doctor

Check whether c4j can find its config, active-project folder, and cmux.
Run this when c4j feels weird.
USAGE
      ;;
    update)
      cat <<'USAGE'
c4j update

Update the installed c4j command.
By default it installs the latest v* release.

Try:
  c4j update
  c4j update --dry-run
  c4j update --ref v0.13.12
  c4j update --repo-url <url> --ref <ref> --allow-unsafe-source
USAGE
      ;;
    worktree|wt|pane|make-pane)
      cat <<'USAGE'
c4j wt [name]

Make a git worktree for the current repo.
If you are inside cmux, c4j can infer the repo from the workspace.

Try:
  c4j wt
  c4j wt feature-api
  c4j wt --dry-run
  c4j wt list

More:
  c4j help wt list
  c4j help wt move
  c4j help wt delete
USAGE
      ;;
    "worktree list"|"wt list"|worktree-list|wt-list)
      cat <<'USAGE'
c4j wt list

Show managed worktrees.
Inside cmux, this usually shows worktrees for the current workspace repo.

Try:
  c4j wt list
  c4j wt list --plain
USAGE
      ;;
    "worktree prune"|"wt prune"|worktree-prune|wt-prune)
      cat <<'USAGE'
c4j wt prune

Clean stale git worktree metadata.

Try:
  c4j wt prune
  c4j wt prune --dry-run
USAGE
      ;;
    "worktree move"|"wt move"|worktree-move|wt-move)
      cat <<'USAGE'
c4j wt move <worktree> <new-name-or-path>

Move a managed worktree.

Try:
  c4j wt move api api-v2
  c4j wt move --dry-run api api-v2
USAGE
      ;;
    "worktree delete"|"wt delete"|worktree-delete|wt-delete)
      cat <<'USAGE'
c4j wt delete [worktree]

Remove a managed worktree.
If you are inside the worktree, you can omit the name.
Dirty or untracked worktrees require --force or --discard.

Try:
  c4j wt delete api
  c4j wt delete --force api
  c4j wt delete --dry-run api
USAGE
      ;;
    "worktree update"|"wt update"|worktree-update|wt-update)
      cat <<'USAGE'
c4j wt update [worktree]

Fetch and fast-forward a managed worktree.
If you are inside the worktree, you can omit the name.

Try:
  c4j wt update api
  c4j wt update --dry-run api
USAGE
      ;;
    version|--version|-v)
      cat <<'USAGE'
c4j version

Print the installed c4j version.
USAGE
      ;;
    *)
      fail "unknown help topic: $topic (try: c4j help)"
      ;;
  esac
}

fail() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

resolve_dir() {
  local path="$1"
  [ -d "$path" ] || return 1
  (cd -- "$path" && pwd -P)
}

slugify_name() {
  local value="$1"
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"
  [ -n "$value" ] || return 1
  printf '%s\n' "$value"
}

canonical_git_root() {
  local path="$1"
  local git_dir

  git_dir="$(git -C "$path" rev-parse --absolute-git-dir 2>/dev/null)" || return 1
  case "$git_dir" in
    */.git/worktrees/*)
      dirname "$(dirname "$(dirname "$git_dir")")"
      ;;
    */.git)
      dirname "$git_dir"
      ;;
    *)
      return 1
      ;;
  esac
}

current_git_ref() {
  local path="$1"
  local branch short_sha

  branch="$(git -C "$path" branch --show-current 2>/dev/null || true)"
  if [ -n "$branch" ]; then
    printf '%s\n' "$branch"
    return 0
  fi

  short_sha="$(git -C "$path" rev-parse --short HEAD 2>/dev/null)" || return 1
  printf 'detached-%s\n' "$short_sha"
}

worktree_registered_at_path() {
  local repo_root="$1"
  local path="$2"

  git -C "$repo_root" worktree list --porcelain | awk -v target="$path" '$1 == "worktree" && $2 == target { found = 1 } END { exit found ? 0 : 1 }'
}

worktree_branch_in_use() {
  local repo_root="$1"
  local branch="$2"

  git -C "$repo_root" worktree list --porcelain | awk -v target="refs/heads/$branch" '$1 == "branch" && $2 == target { found = 1 } END { exit found ? 0 : 1 }'
}

git_branch_exists() {
  local repo_root="$1"
  local branch="$2"

  git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"
}

is_safe_name() {
  local name="$1"
  [ -n "$name" ] || return 1
  [ "$name" != "." ] || return 1
  [ "$name" != ".." ] || return 1
  case "$name" in
    */*|*..*) return 1 ;;
  esac
  return 0
}

find_cmux() {
  if [ -n "$CMUX_BIN" ]; then
    printf '%s\n' "$CMUX_BIN"
  elif command -v cmux >/dev/null 2>&1; then
    command -v cmux
  elif [ -x "/Applications/cmux.app/Contents/Resources/bin/cmux" ]; then
    printf '%s\n' "/Applications/cmux.app/Contents/Resources/bin/cmux"
  else
    printf '%s\n' "cmux"
  fi
}

cmux_available() {
  local cmux_bin="$1"
  command -v "$cmux_bin" >/dev/null 2>&1 || [ -x "$cmux_bin" ]
}

has_direction() {
  local direction="$1"
  local requested="$2"
  case "$direction:$requested" in
    active-to-cmux:active-to-cmux|both:active-to-cmux|cmux-to-active:cmux-to-active|both:cmux-to-active)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

load_cmux_inventory() {
  local cmux_bin="$1"
  local output_file="$2"
  : > "$output_file"

  cmux_available "$cmux_bin" || return 1

  local json
  json="$("$cmux_bin" --json list-workspaces 2>/dev/null)" || return 1

  local parsed_file
  parsed_file="$(mktemp)"

  if command -v python3 >/dev/null 2>&1; then
    if JSON_INPUT="$json" python3 - "$parsed_file" <<'PY'
import json
import os
import sys

output_path = sys.argv[1]
data = json.loads(os.environ["JSON_INPUT"])
with open(output_path, "w", encoding="utf-8") as handle:
    for workspace in data.get("workspaces", []):
        title = workspace.get("title")
        cwd = workspace.get("current_directory")
        ref = workspace.get("ref")
        if (
            isinstance(title, str)
            and isinstance(cwd, str)
            and isinstance(ref, str)
            and not any(ch in title for ch in "\t\r\n")
            and not any(ch in cwd for ch in "\t\r\n")
            and not any(ch in ref for ch in "\t\r\n")
        ):
            handle.write(f"{title}\t{cwd}\t{ref}\n")
PY
    then
      mv "$parsed_file" "$output_file"
      return 0
    fi
    rm -f "$parsed_file"
    return 1
  fi

  if command -v jq >/dev/null 2>&1; then
    if printf '%s\n' "$json" | jq -r '.workspaces[] | select(.title and .current_directory and .ref) | select((.title | test("[\\t\\r\\n]") | not) and (.current_directory | test("[\\t\\r\\n]") | not) and (.ref | test("[\\t\\r\\n]") | not)) | [.title, .current_directory, .ref] | @tsv' > "$parsed_file"; then
      mv "$parsed_file" "$output_file"
      return 0
    fi
    rm -f "$parsed_file"
    return 1
  fi

  rm -f "$parsed_file"

  return 1
}

cmux_workspace_directory() {
  local cmux_bin="$1"

  cmux_available "$cmux_bin" || return 1

  local identify_json inventory_file workspace_ref
  identify_json="$("$cmux_bin" identify --json 2>/dev/null)" || return 1

  if command -v python3 >/dev/null 2>&1; then
    if ! workspace_ref="$(IDENTIFY_JSON="$identify_json" python3 - <<'PY'
import json
import os
import sys

data = json.loads(os.environ["IDENTIFY_JSON"])
for key in ("caller", "focused"):
    block = data.get(key, {})
    ref = block.get("workspace_ref")
    if isinstance(ref, str) and ref and not any(ch in ref for ch in "\t\r\n"):
        print(ref)
        sys.exit(0)
sys.exit(1)
PY
    )"; then
      return 1
    fi
  elif command -v jq >/dev/null 2>&1; then
    workspace_ref="$(printf '%s\n' "$identify_json" | jq -r '.caller.workspace_ref // .focused.workspace_ref // empty')"
  else
    return 1
  fi

  [ -n "$workspace_ref" ] || return 1

  inventory_file="$(mktemp)"
  if ! load_cmux_inventory "$cmux_bin" "$inventory_file"; then
    rm -f "$inventory_file"
    return 1
  fi

  awk -F '\t' -v ref="$workspace_ref" '
    $3 == ref {
      print $2
      found = 1
      exit
    }
    END { exit found ? 0 : 1 }
  ' "$inventory_file"
  local status=$?
  rm -f "$inventory_file"
  return "$status"
}

worktree_repo_root_for_path() {
  local path="$1"

  git -C "$path" rev-parse --show-toplevel 2>/dev/null || return 1
}

worktree_repo_root_from_cmux() {
  local cmux_bin="$1" workspace_dir repo_root

  workspace_dir="$(cmux_workspace_directory "$cmux_bin" 2>/dev/null || true)"
  [ -n "$workspace_dir" ] || return 1
  repo_root="$(worktree_repo_root_for_path "$workspace_dir" 2>/dev/null || true)"
  [ -n "$repo_root" ] || return 1
  printf '%s\n' "$repo_root"
}

discover_worktree_repo_roots() {
  local output_file="$1"
  local repos_root="${HOME:-/Users/justn}/Workspaces/repos"
  local worktree_root="${WORKTREE_DIR%/}"
  local gitdir worktree_dir repo_root

  : > "$output_file"

  if [ -d "$repos_root" ]; then
    while IFS= read -r gitdir; do
      [ -n "$gitdir" ] || continue
      dirname "$gitdir" >> "$output_file"
    done < <(find "$repos_root" -type d -name .git -print 2>/dev/null)
  fi

  if [ -d "$worktree_root" ]; then
    while IFS= read -r -d '' gitdir; do
      worktree_dir="$(dirname "$gitdir")"
      repo_root="$(canonical_git_root "$worktree_dir" 2>/dev/null || true)"
      [ -n "$repo_root" ] || continue
      printf '%s\n' "$repo_root" >> "$output_file"
    done < <(find "$worktree_root" -type f -name .git -print0 2>/dev/null)
  fi

  sort -u "$output_file" -o "$output_file"
}

collect_worktree_rows() {
  local rows_file="$1"
  local scope_repo_root="${2:-}"
  local roots_file

  : > "$rows_file"
  roots_file="$(mktemp)"

  if [ -n "$scope_repo_root" ]; then
    printf '%s\n' "$scope_repo_root" > "$roots_file"
  else
    discover_worktree_repo_roots "$roots_file"
  fi

  local repo_root
  while IFS= read -r repo_root; do
    [ -n "$repo_root" ] || continue
    [ -d "$repo_root" ] || continue
    append_worktree_rows_for_repo_root "$repo_root" "$rows_file"
  done < "$roots_file"

  sort -t "$(printf '\t')" -k1,1 -k2,2 -k3,3 "$rows_file" -o "$rows_file"
  rm -f "$roots_file"
}

append_worktree_rows_for_repo_root() {
  local repo_root="$1"
  local rows_file="$2"
  local repo_name current_path current_branch line name branch_display

  repo_name="$(basename "$repo_root")"
  current_path=""
  current_branch=""

  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      worktree\ *)
        if [ -n "$current_path" ]; then
          name="$(basename "$current_path")"
          if [ "$current_path" = "$repo_root" ]; then
            name="$repo_name"
          fi
          branch_display="${current_branch:-detached}"
          printf '%s\t%s\t%s\t%s\t%s\n' "$repo_root" "$repo_name" "$name" "$current_path" "$branch_display" >> "$rows_file"
        fi
        current_path="${line#worktree }"
        current_branch=""
        ;;
      branch\ *)
        current_branch="${line#branch refs/heads/}"
        ;;
      detached)
        current_branch="detached"
        ;;
      "")
        if [ -n "$current_path" ]; then
          name="$(basename "$current_path")"
          if [ "$current_path" = "$repo_root" ]; then
            name="$repo_name"
          fi
          branch_display="${current_branch:-detached}"
          printf '%s\t%s\t%s\t%s\t%s\n' "$repo_root" "$repo_name" "$name" "$current_path" "$branch_display" >> "$rows_file"
          current_path=""
          current_branch=""
        fi
        ;;
    esac
  done < <(git -C "$repo_root" worktree list --porcelain 2>/dev/null || true)

  if [ -n "$current_path" ]; then
    name="$(basename "$current_path")"
    if [ "$current_path" = "$repo_root" ]; then
      name="$repo_name"
    fi
    branch_display="${current_branch:-detached}"
    printf '%s\t%s\t%s\t%s\t%s\n' "$repo_root" "$repo_name" "$name" "$current_path" "$branch_display" >> "$rows_file"
  fi
}

worktree_render_rows() {
  local rows_file="$1"
  local mode="${2:-table}"
  local repo_width name_width path_width branch_width

  if [ ! -s "$rows_file" ]; then
    printf 'No worktrees found.\n'
    return 0
  fi

  if [ "$mode" = "plain" ]; then
    cat "$rows_file"
    return 0
  fi

  repo_width="$(awk -F '\t' 'BEGIN { max = length("REPO") } { if (length($2) > max) max = length($2) } END { print max }' "$rows_file")"
  name_width="$(awk -F '\t' 'BEGIN { max = length("WORKTREE") } { if (length($3) > max) max = length($3) } END { print max }' "$rows_file")"
  path_width="$(awk -F '\t' 'BEGIN { max = length("PATH") } { if (length($4) > max) max = length($4) } END { print max }' "$rows_file")"
  branch_width="$(awk -F '\t' 'BEGIN { max = length("BRANCH") } { if (length($5) > max) max = length($5) } END { print max }' "$rows_file")"

  printf "%-${repo_width}s  %-${name_width}s  %-${path_width}s  %s\n" "REPO" "WORKTREE" "PATH" "BRANCH"
  printf "%-${repo_width}s  %-${name_width}s  %-${path_width}s  %s\n" "$(printf '%*s' "$repo_width" '' | tr ' ' '-')" "$(printf '%*s' "$name_width" '' | tr ' ' '-')" "$(printf '%*s' "$path_width" '' | tr ' ' '-')" "$(printf '%*s' "$branch_width" '' | tr ' ' '-')"
  awk -F '\t' -v repo_width="$repo_width" -v name_width="$name_width" -v path_width="$path_width" '{ printf "%-" repo_width "s  %-" name_width "s  %-" path_width "s  %s\n", $2, $3, $4, $5 }' "$rows_file"
}

worktree_find_rows() {
  local rows_file="$1"
  local target="$2"
  local matches_file="$3"
  : > "$matches_file"

  while IFS=$'\t' read -r repo_root repo_name worktree_name worktree_path branch; do
    [ -n "$repo_root" ] || continue
    case "$target" in
      "$worktree_path"|"$worktree_name"|"$branch"|worktree/"$target"|"$repo_root")
        printf '%s\t%s\t%s\t%s\t%s\n' "$repo_root" "$repo_name" "$worktree_name" "$worktree_path" "$branch" >> "$matches_file"
        ;;
    esac
  done < "$rows_file"
}

worktree_current_path_from_pwd() {
  local top repo_root

  top="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null)" || return 1
  repo_root="$(canonical_git_root "$top" 2>/dev/null || true)"
  [ -n "$repo_root" ] || return 1
  [ "$top" != "$repo_root" ] || return 1
  printf '%s\n' "$top"
}

worktree_repo_root_for_context() {
  local repo_path="${1:-}"
  local cmux_bin current_workspace_root current_pwd_root

  if [ -n "$repo_path" ]; then
    worktree_repo_root_for_path "$repo_path"
    return
  fi

  cmux_bin="$(find_cmux)"
  current_workspace_root="$(worktree_repo_root_from_cmux "$cmux_bin" 2>/dev/null || true)"
  if [ -n "$current_workspace_root" ]; then
    printf '%s\n' "$current_workspace_root"
    return 0
  fi

  current_pwd_root="$(worktree_repo_root_for_path "$PWD" 2>/dev/null || true)"
  [ -n "$current_pwd_root" ] || return 1
  printf '%s\n' "$current_pwd_root"
}

worktree_update_target_path() {
  local target="${1:-}"
  local resolved=""

  if [ -n "$target" ] && [ -e "$target" ]; then
    resolved="$(resolve_dir "$target" 2>/dev/null || true)"
    [ -n "$resolved" ] || fail "worktree target is not a directory: $target"
    printf '%s\n' "$resolved"
    return 0
  fi

  if [ -n "$target" ]; then
    return 1
  fi

  if resolved="$(worktree_current_path_from_pwd 2>/dev/null || true)"; then
    if [ -n "$resolved" ]; then
      printf '%s\n' "$resolved"
      return 0
    fi
  fi

  return 1
}

update_latest_release_ref() {
  local repo_url="$1"
  local ref ls_remote_output

  if command -v python3 >/dev/null 2>&1; then
    ls_remote_output="$(git ls-remote --tags --refs "$repo_url" 'v*' 2>/dev/null)"
    ref="$(LS_REMOTE_OUTPUT="$ls_remote_output" python3 - <<'PY'
import re
import os
import sys

tags = []
for line in os.environ.get("LS_REMOTE_OUTPUT", "").splitlines():
    parts = line.rstrip("\n").split("\t")
    if len(parts) >= 2 and parts[1].startswith("refs/tags/"):
        tags.append(parts[1][len("refs/tags/"):])

def version_key(tag: str):
    core = tag[1:] if tag.startswith("v") else tag
    parts = []
    for chunk in core.split("."):
        match = re.match(r"(\d+)", chunk)
        parts.append(int(match.group(1)) if match else -1)
    return parts

if tags:
    print(sorted(tags, key=version_key)[-1])
PY
    )"
  else
    ref="$(git ls-remote --tags --refs "$repo_url" 'v*' 2>/dev/null | awk '{ print $2 }' | sed 's#refs/tags/##' | tail -n 1)"
  fi
  [ -n "$ref" ] || return 1
  printf '%s\n' "$ref"
}

update_source_checkout() {
  local install_dir="$1"
  local repo_url="$2"
  local ref="$3"

  if [ -d "$install_dir/.git" ]; then
    if [ -n "$(git -C "$install_dir" status --porcelain 2>/dev/null)" ]; then
      fail "install checkout has local changes: $install_dir (commit, stash, or remove them before updating)"
    fi
    git -C "$install_dir" fetch -q --depth 1 "$repo_url" "$ref"
    git -C "$install_dir" -c advice.detachedHead=false checkout -q -f FETCH_HEAD
  else
    mkdir -p "$(dirname "$install_dir")"
    git clone -q --depth 1 --no-checkout "$repo_url" "$install_dir"
    git -C "$install_dir" fetch -q --depth 1 origin "$ref"
    git -C "$install_dir" -c advice.detachedHead=false checkout -q FETCH_HEAD
  fi
}

update_remote_ref_commit() {
  local repo_url="$1"
  local ref="$2"
  git ls-remote "$repo_url" "$ref" 2>/dev/null | awk 'NR == 1 { print $1 }'
}

trusted_source_ref() {
  case "$1" in
    v[0-9]*)
      case "$1" in
        */*|*..*|"") return 1 ;;
        *) return 0 ;;
      esac
      ;;
    *) return 1 ;;
  esac
}

validate_update_source_policy() {
  local repo_url="$1"
  local ref="$2"
  local allow_unsafe_source="$3"

  [ "$allow_unsafe_source" -eq 0 ] || return 0
  [ "$repo_url" = "$DEFAULT_REPO_URL" ] || fail "unsafe source requires --allow-unsafe-source: repo-url $repo_url"
  trusted_source_ref "$ref" || fail "unsafe source requires --allow-unsafe-source: ref $ref is not a trusted v* tag"
}

worktree_base_path_for_root() {
  local canonical_root="$1"
  local repo_slug relative_repo_path repos_root

  case "$canonical_root" in
    */Workspaces/repos/*)
      repos_root="${canonical_root%%/Workspaces/repos/*}/Workspaces/repos"
      relative_repo_path="${canonical_root#"$repos_root"/}"
      printf '%s\n' "${repos_root%/repos}/worktrees/$relative_repo_path"
      ;;
    *)
      repo_slug="$(slugify_name "$(basename "$canonical_root")")" || return 1
      printf '%s\n' "$WORKTREE_DIR/external/$repo_slug"
      ;;
  esac
}

worktree_move_destination_path() {
  local repo_root="$1"
  local destination="$2"
  local canonical_root worktree_base parent resolved_parent

  case "$destination" in
    ~) destination="$HOME" ;;
    ~/*) destination="$HOME/${destination#~/}" ;;
  esac

  case "$destination" in
    /*)
      printf '%s\n' "$destination"
      return 0
      ;;
    */*)
      parent="$(dirname "$destination")"
      [ -d "$parent" ] || return 1
      resolved_parent="$(cd "$parent" && pwd -P)" || return 1
      printf '%s/%s\n' "$resolved_parent" "$(basename "$destination")"
      return 0
      ;;
  esac

  canonical_root="$(canonical_git_root "$repo_root")" || return 1
  worktree_base="$(worktree_base_path_for_root "$canonical_root")" || return 1
  printf '%s/%s\n' "$worktree_base" "$(slugify_name "$destination")"
}

workspace_title_exists() {
  local inventory_file="$1"
  local title="$2"
  awk -F '\t' -v title="$title" '$1 == title { found = 1 } END { exit found ? 0 : 1 }' "$inventory_file"
}

workspace_ref_for_title() {
  local inventory_file="$1"
  local title="$2"
  awk -F '\t' -v title="$title" '$1 == title { print $3; found = 1; exit } END { exit found ? 0 : 1 }' "$inventory_file"
}

workspace_cwd_for_title() {
  local inventory_file="$1"
  local title="$2"
  awk -F '\t' -v title="$title" '$1 == title { print $2; found = 1; exit } END { exit found ? 0 : 1 }' "$inventory_file"
}

if ! declare -F print_apply_hint >/dev/null 2>&1; then
print_apply_hint() {
  local command="$1"
  shift
  printf 'note\tdry-run\tapply with: c4j %s' "$command"
  if [ "$#" -gt 0 ]; then
    printf ' %s' "$@"
  fi
  printf ' --apply\n'
}
fi

if ! declare -F config_key_for_field >/dev/null 2>&1; then
config_key_for_field() {
  case "$1" in
    active-dir|workspace-dir|workspace-file)
      printf 'active_dir\n'
      ;;
    cmux-bin)
      printf 'cmux_bin\n'
      ;;
    name-prefix|prefix|workspace-prefix)
      printf 'name_prefix\n'
      ;;
    *)
      return 1
      ;;
  esac
}
fi

if ! declare -F config_value_for_field >/dev/null 2>&1; then
config_value_for_field() {
  local field="$1"
  local value="$2"
  case "$field" in
    active-dir|workspace-dir|workspace-file)
      resolve_dir "$value" || return 1
      ;;
    cmux-bin)
      [ -n "$value" ] || return 1
      case "$value" in
        *$'\t'*|*$'\r'*|*$'\n'*) return 1 ;;
      esac
      printf '%s\n' "$value"
      ;;
    name-prefix|prefix|workspace-prefix)
      [ -n "$value" ] || return 1
      case "$value" in
        *$'\t'*|*$'\r'*|*$'\n'*) return 1 ;;
      esac
      printf '%s\n' "$value"
      ;;
    *)
      return 1
      ;;
  esac
}
fi

if ! declare -F config_write_value >/dev/null 2>&1; then
config_write_value() {
  local key="$1"
  local value="$2"
  local dir tmp_file
  dir="$(dirname "$CONFIG_FILE")"
  mkdir -p "$dir"
  tmp_file="$(mktemp "$dir/.c4j.config.XXXXXX")"
  if [ -f "$CONFIG_FILE" ]; then
    awk -F '=' -v key="$key" '$1 != key { print }' "$CONFIG_FILE" > "$tmp_file"
  fi
  printf '%s=%s\n' "$key" "$value" >> "$tmp_file"
  mv "$tmp_file" "$CONFIG_FILE"
}
fi

if ! declare -F config_unset_value >/dev/null 2>&1; then
config_unset_value() {
  local key="$1"
  local tmp_file
  [ -f "$CONFIG_FILE" ] || return 0
  tmp_file="$(mktemp "$(dirname "$CONFIG_FILE")/.c4j.config.XXXXXX")"
  awk -F '=' -v key="$key" '$1 != key { print }' "$CONFIG_FILE" > "$tmp_file"
  mv "$tmp_file" "$CONFIG_FILE"
}
fi

cmd_config() {
  local subcommand="${1:-}"
  case "$subcommand" in
    get|"")
      [ "$#" -le 1 ] || fail "config get takes no arguments"
      tsv_row config_file "$CONFIG_FILE"
      tsv_row active_dir "$ACTIVE_DIR"
      tsv_row cmux_bin "$(find_cmux)"
      tsv_row name_prefix "$NAME_PREFIX"
      ;;
    set)
      [ "$#" -eq 3 ] || fail "config set requires a field and value"
      local field="$2"
      local value="$3"
      local key resolved
      key="$(config_key_for_field "$field")" || fail "unknown config field: $field"
      resolved="$(config_value_for_field "$field" "$value")" || fail "invalid value for $field: $value"
      config_write_value "$key" "$resolved"
      tsv_row set "$key" "$resolved"
      ;;
    unset)
      [ "$#" -eq 2 ] || fail "config unset requires a field"
      local field="$2"
      local key
      key="$(config_key_for_field "$field")" || fail "unknown config field: $field"
      config_unset_value "$key"
      tsv_row unset "$key"
      ;;
    path)
      [ "$#" -eq 1 ] || fail "config path takes no arguments"
      printf '%s\n' "$CONFIG_FILE"
      ;;
    -h|--help|help)
      command_help config
      ;;
    *)
      fail "unknown config command: $subcommand"
      ;;
  esac
}

cmd_setup() {
  local mode="apply"
  local active_dir=""
  local name_prefix="@active/"
  local active_dir_set=0
  local name_prefix_set=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --active-dir)
        [ "$#" -ge 2 ] || fail "--active-dir requires a path"
        active_dir="$2"
        active_dir_set=1
        shift 2
        ;;
      --name-prefix|--prefix)
        [ "$#" -ge 2 ] || fail "--name-prefix requires text"
        name_prefix="$2"
        name_prefix_set=1
        shift 2
        ;;
      -h|--help)
        command_help setup
        exit 0
        ;;
      *)
        fail "unknown setup option: $1"
        ;;
    esac
  done

  local resolved_name_prefix resolved_active_dir=""
  resolved_name_prefix="$(config_value_for_field name-prefix "$name_prefix")" || fail "invalid value for name-prefix: $name_prefix"
  if [ -n "$active_dir" ]; then
    resolved_active_dir="$(config_value_for_field active-dir "$active_dir")" || fail "invalid value for active-dir: $active_dir"
  fi

  if [ "$mode" = "dry-run" ]; then
    tsv_row would-set name_prefix "$resolved_name_prefix"
    if [ -n "$active_dir" ]; then
      tsv_row would-set active_dir "$resolved_active_dir"
    fi
    local hint_args=()
    if [ "$active_dir_set" -eq 1 ]; then
      hint_args+=(--active-dir "$active_dir")
    fi
    if [ "$name_prefix_set" -eq 1 ]; then
      hint_args+=(--name-prefix "$name_prefix")
    fi
    print_apply_hint setup "${hint_args[@]}"
    return
  fi

  config_write_value name_prefix "$resolved_name_prefix"
  tsv_row set name_prefix "$resolved_name_prefix"

  if [ -n "$active_dir" ]; then
    config_write_value active_dir "$resolved_active_dir"
    tsv_row set active_dir "$resolved_active_dir"
  fi
}

cmd_add() {
  local mode="apply"
  local apply_set=0
  local paths=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        apply_set=1
        shift
        ;;
      -h|--help)
        command_help add
        exit 0
        ;;
      --)
        shift
        while [ "$#" -gt 0 ]; do
          paths+=("$1")
          shift
        done
        ;;
      --*)
        fail "unknown add option: $1"
        ;;
      *)
        paths+=("$1")
        shift
        ;;
    esac
  done

  [ -d "$ACTIVE_DIR" ] || fail "active directory not found: $ACTIVE_DIR"

  if [ "${#paths[@]}" -eq 0 ]; then
    if [ "$apply_set" -eq 1 ]; then
      cmd_sync --direction both --apply
    else
      cmd_sync --direction both --dry-run
    fi
    return
  fi

  local path target name link existing
  for path in "${paths[@]}"; do
    target="$(resolve_dir "$path")" || fail "not a directory: $path"
    name="$(basename "$target")"
    is_safe_name "$name" || fail "unsafe active name: $name"
    link="$ACTIVE_DIR/$name"

    if [ -L "$link" ]; then
      existing="$(resolve_dir "$link")" || fail "existing active link is broken: $link"
      if [ "$existing" = "$target" ]; then
        printf 'skip existing-link\t%s\t%s\n' "$name" "$target"
        continue
      fi
      fail "active link already points elsewhere: $link -> $existing"
    fi

    if [ -e "$link" ]; then
      fail "active path already exists and is not a symlink: $link"
    fi

    if [ "$mode" = "dry-run" ]; then
      printf 'would-link\t%s\t%s\n' "$link" "$target"
    else
      printf 'link\t%s\t%s\n' "$link" "$target"
      ln -s "$target" "$link"
    fi
  done

  cmd_sync --direction both "--$mode"
}

active_name_for_query() {
  local query="$1"
  local query_lower matches_file

  is_safe_name "$query" || return 1

  if [ -L "$ACTIVE_DIR/$query" ]; then
    printf '%s\n' "$query"
    return 0
  fi

  query_lower="$(printf '%s\n' "$query" | tr '[:upper:]' '[:lower:]')"
  matches_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$matches_file'" RETURN

  shopt -s nullglob
  local link name name_lower
  for link in "$ACTIVE_DIR"/*; do
    [ -L "$link" ] || continue
    name="$(basename "$link")"
    name_lower="$(printf '%s\n' "$name" | tr '[:upper:]' '[:lower:]')"
    if [ "$name_lower" = "$query_lower" ]; then
      printf '%s\n' "$name" >> "$matches_file"
    fi
  done
  shopt -u nullglob

  local match_count
  match_count="$(wc -l < "$matches_file" | tr -d ' ')"
  if [ "$match_count" -eq 1 ]; then
    cat "$matches_file"
    return 0
  fi
  if [ "$match_count" -gt 1 ]; then
    cat "$matches_file"
    return 2
  fi
  return 1
}

cmd_go() {
  local mode="apply"
  local cmux_enabled=1
  local cmux_bin
  local query=""
  cmux_bin="$(find_cmux)"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --no-cmux)
        cmux_enabled=0
        shift
        ;;
      --active-dir)
        [ "$#" -ge 2 ] || fail "--active-dir requires a path"
        ACTIVE_DIR="$2"
        shift 2
        ;;
      --cmux)
        [ "$#" -ge 2 ] || fail "--cmux requires a path"
        cmux_bin="$2"
        shift 2
        ;;
      --name-prefix)
        [ "$#" -ge 2 ] || fail "--name-prefix requires text"
        NAME_PREFIX="$2"
        shift 2
        ;;
      -h|--help)
        command_help go
        exit 0
        ;;
      --)
        shift
        [ "$#" -eq 1 ] || fail "go requires exactly one name or path"
        query="$1"
        shift
        ;;
      --*)
        fail "unknown go option: $1"
        ;;
      *)
        [ -z "$query" ] || fail "go requires exactly one name or path"
        query="$1"
        shift
        ;;
    esac
  done

  [ -n "$query" ] || fail "go requires a name or path"
  [ -d "$ACTIVE_DIR" ] || fail "active directory not found: $ACTIVE_DIR"

  local target name link existing added_link=0 workspace_name
  if target="$(resolve_dir "$query" 2>/dev/null)"; then
    name="$(basename "$target")"
  else
    local name_status=0
    name="$(active_name_for_query "$query")" || name_status=$?
    if [ "$name_status" -eq 2 ]; then
      fail "active project is ambiguous: $query ($(printf '%s\n' "$name" | tr '\n' ' ' | sed 's/[[:space:]]*$//'))"
    fi
    [ "$name_status" -eq 0 ] || fail "active project not found: $query"
    target="$(resolve_dir "$ACTIVE_DIR/$name")" || fail "active link is broken: $ACTIVE_DIR/$name"
  fi

  is_safe_name "$name" || fail "unsafe active name: $name"
  link="$ACTIVE_DIR/$name"
  workspace_name="${NAME_PREFIX}${name}"

  local inventory_file="" inventory_loaded=0 workspace_ref="" workspace_cwd=""
  if [ "$cmux_enabled" -eq 1 ]; then
    inventory_file="$(mktemp)"
    # shellcheck disable=SC2064
    trap "rm -f '$inventory_file'" RETURN

    if load_cmux_inventory "$cmux_bin" "$inventory_file"; then
      inventory_loaded=1
      workspace_ref="$(workspace_ref_for_title "$inventory_file" "$workspace_name" 2>/dev/null || true)"
      workspace_cwd="$(workspace_cwd_for_title "$inventory_file" "$workspace_name" 2>/dev/null || true)"
      if [ -n "$workspace_ref" ] && [ "$workspace_cwd" != "$target" ]; then
        fail "workspace already points elsewhere: $workspace_name -> $workspace_cwd"
      fi
    elif [ "$mode" = "apply" ]; then
      fail "cannot read cmux workspace inventory for apply go"
    fi
  fi

  if [ -L "$link" ]; then
    existing="$(resolve_dir "$link")" || fail "existing active link is broken: $link"
    [ "$existing" = "$target" ] || fail "active link already points elsewhere: $link -> $existing"
  elif [ -e "$link" ]; then
    fail "active path already exists and is not a symlink: $link"
  elif [ "$mode" = "dry-run" ]; then
    printf 'would-link\t%s\t%s\n' "$link" "$target"
    added_link=1
  else
    ln -s "$target" "$link"
    printf 'link\t%s\t%s\n' "$link" "$target"
    added_link=1
  fi

  if [ "$cmux_enabled" -eq 1 ]; then
    if [ "$inventory_loaded" -eq 1 ]; then
      if [ -n "$workspace_ref" ]; then
        if [ "$mode" = "dry-run" ]; then
          printf 'would-select-workspace\t%s\t%s\n' "$workspace_name" "$workspace_ref"
        else
          "$cmux_bin" select-workspace --workspace "$workspace_ref" >/dev/null
          printf 'select-workspace\t%s\t%s\n' "$workspace_name" "$workspace_ref"
        fi
      elif [ "$mode" = "dry-run" ]; then
        printf 'would-create-workspace\t%s\t%s\n' "$workspace_name" "$target"
      else
        "$cmux_bin" new-workspace --name "$workspace_name" --cwd "$target" --focus true >/dev/null
        printf 'create-workspace\t%s\t%s\n' "$workspace_name" "$target"
      fi
    else
      printf 'skip cmux-unavailable\t%s\n' "$workspace_name"
    fi
  else
    printf 'skip cmux-disabled\t%s\n' "$workspace_name"
  fi

  if [ "$mode" = "dry-run" ]; then
    printf 'would-go-project\t%s\t%s\n' "$name" "$target"
    print_apply_hint go "$query"
  else
    printf '%s\t%s\t%s\n' "$C4J_ACTION_GO_PROJECT" "$name" "$target"
  fi

  [ "$added_link" -eq 0 ] || true
}

cmd_cd() {
  local mode="apply"
  local query=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --active-dir)
        [ "$#" -ge 2 ] || fail "--active-dir requires a path"
        ACTIVE_DIR="$2"
        shift 2
        ;;
      -h|--help)
        command_help cd
        exit 0
        ;;
      --)
        shift
        [ "$#" -eq 1 ] || fail "cd requires exactly one name or path"
        query="$1"
        shift
        ;;
      --*)
        fail "unknown cd option: $1"
        ;;
      *)
        [ -z "$query" ] || fail "cd requires exactly one name or path"
        query="$1"
        shift
        ;;
    esac
  done

  [ -n "$query" ] || fail "cd requires a name or path"
  [ -d "$ACTIVE_DIR" ] || fail "active directory not found: $ACTIVE_DIR"

  local target name
  if target="$(resolve_dir "$query" 2>/dev/null)"; then
    name="$(basename "$target")"
  else
    local name_status=0
    name="$(active_name_for_query "$query")" || name_status=$?
    if [ "$name_status" -eq 2 ]; then
      fail "active project is ambiguous: $query ($(printf '%s\n' "$name" | tr '\n' ' ' | sed 's/[[:space:]]*$//'))"
    fi
    [ "$name_status" -eq 0 ] || fail "active project not found: $query"
    target="$(resolve_dir "$ACTIVE_DIR/$name")" || fail "active link is broken: $ACTIVE_DIR/$name"
  fi

  is_safe_name "$name" || fail "unsafe active name: $name"

  if [ "$mode" = "dry-run" ]; then
    printf 'would-cd-project\t%s\t%s\n' "$name" "$target"
  else
    printf '%s\t%s\t%s\n' "$C4J_ACTION_CD_PROJECT" "$name" "$target"
  fi
}

cmd_anchor() {
  local mode="apply"
  local cmux_bin
  local anchor_name="${C4J_ANCHOR_NAME:-justn-is-always-around-here}"
  local anchor_cwd="${C4J_ANCHOR_DIR:-$DEFAULT_ANCHOR_DIR}"
  local anchor_color="${C4J_ANCHOR_COLOR:-Teal}"
  local anchor_description="${C4J_ANCHOR_DESCRIPTION:-Anchor workspace for ~/Workspaces, parent of now/.}"
  cmux_bin="$(find_cmux)"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --name)
        [ "$#" -ge 2 ] || fail "--name requires text"
        anchor_name="$2"
        shift 2
        ;;
      --cwd|--dir)
        [ "$#" -ge 2 ] || fail "--cwd requires a path"
        anchor_cwd="$2"
        shift 2
        ;;
      --color)
        [ "$#" -ge 2 ] || fail "--color requires text"
        anchor_color="$2"
        shift 2
        ;;
      --description)
        [ "$#" -ge 2 ] || fail "--description requires text"
        anchor_description="$2"
        shift 2
        ;;
      --cmux)
        [ "$#" -ge 2 ] || fail "--cmux requires a path"
        cmux_bin="$2"
        shift 2
        ;;
      -h|--help)
        command_help anchor
        exit 0
        ;;
      *)
        fail "unknown anchor option: $1"
        ;;
    esac
  done

  [ -n "$anchor_name" ] || fail "anchor name cannot be empty"
  case "$anchor_name" in
    *$'\t'*|*$'\r'*|*$'\n'*) fail "anchor name cannot contain control whitespace" ;;
  esac
  anchor_cwd="$(resolve_dir "$anchor_cwd")" || fail "anchor cwd is not a directory: $anchor_cwd"

  if [ "$mode" = "apply" ] && ! cmux_available "$cmux_bin"; then
    fail "cmux executable not found: $cmux_bin"
  fi

  local inventory_file
  inventory_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$inventory_file'" RETURN

  local inventory_loaded=0
  if load_cmux_inventory "$cmux_bin" "$inventory_file"; then
    inventory_loaded=1
  fi

  if [ "$mode" = "apply" ] && [ "$inventory_loaded" -ne 1 ]; then
    fail "cannot read cmux workspace inventory for apply anchor"
  fi

  local anchor_ref=""
  if [ "$inventory_loaded" -eq 1 ]; then
    anchor_ref="$(workspace_ref_for_title "$inventory_file" "$anchor_name" 2>/dev/null || true)"
  fi

  if [ -n "$anchor_ref" ]; then
    printf 'skip existing-anchor\t%s\t%s\n' "$anchor_name" "$anchor_ref"
  elif [ "$mode" = "apply" ]; then
    "$cmux_bin" new-workspace --name "$anchor_name" --cwd "$anchor_cwd" --focus false >/dev/null
    printf 'create-anchor\t%s\t%s\n' "$anchor_name" "$anchor_cwd"
    if load_cmux_inventory "$cmux_bin" "$inventory_file"; then
      anchor_ref="$(workspace_ref_for_title "$inventory_file" "$anchor_name" 2>/dev/null || true)"
    fi
  else
    printf 'would-create-anchor\t%s\t%s\n' "$anchor_name" "$anchor_cwd"
  fi

  if [ "$mode" = "apply" ]; then
    if [ -n "$anchor_ref" ]; then
      "$cmux_bin" workspace-action --workspace "$anchor_ref" --action pin >/dev/null || true
      "$cmux_bin" workspace-action --workspace "$anchor_ref" --action set-color --color "$anchor_color" >/dev/null || true
      "$cmux_bin" workspace-action --workspace "$anchor_ref" --action set-description --description "$anchor_description" >/dev/null || true
      printf 'pin-anchor\t%s\t%s\n' "$anchor_name" "$anchor_ref"
      printf 'set-anchor-color\t%s\t%s\n' "$anchor_name" "$anchor_color"
      printf 'set-anchor-description\t%s\t%s\n' "$anchor_name" "$anchor_description"
    else
      printf 'skip anchor-actions-unavailable\t%s\n' "$anchor_name"
    fi
  else
    printf 'would-pin-anchor\t%s\n' "$anchor_name"
    printf 'would-set-anchor-color\t%s\t%s\n' "$anchor_name" "$anchor_color"
    printf 'would-set-anchor-description\t%s\t%s\n' "$anchor_name" "$anchor_description"
    print_apply_hint anchor
  fi
}

active_name_from_delete_arg() {
  local arg="$1"
  local target

  if target="$(resolve_dir "$arg" 2>/dev/null)"; then
    basename "$target"
    return 0
  fi

  case "$arg" in
    "$NAME_PREFIX"*)
      printf '%s\n' "${arg#"$NAME_PREFIX"}"
      ;;
    */*)
      fail "delete target is not an existing directory or active name: $arg"
      ;;
    *)
      printf '%s\n' "$arg"
      ;;
  esac
}

cmd_delete() {
  local mode="apply"
  local close_cmux=1
  local cmux_bin
  local targets=()
  cmux_bin="$(find_cmux)"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --keep-cmux)
        close_cmux=0
        shift
        ;;
      --active-dir)
        [ "$#" -ge 2 ] || fail "--active-dir requires a path"
        ACTIVE_DIR="$2"
        shift 2
        ;;
      --cmux)
        [ "$#" -ge 2 ] || fail "--cmux requires a path"
        cmux_bin="$2"
        shift 2
        ;;
      --name-prefix)
        [ "$#" -ge 2 ] || fail "--name-prefix requires text"
        NAME_PREFIX="$2"
        shift 2
        ;;
      -h|--help)
        command_help delete
        exit 0
        ;;
      --)
        shift
        while [ "$#" -gt 0 ]; do
          targets+=("$1")
          shift
        done
        ;;
      --*)
        fail "unknown delete option: $1"
        ;;
      *)
        targets+=("$1")
        shift
        ;;
    esac
  done

  [ "${#targets[@]}" -gt 0 ] || fail "delete requires at least one name or path"
  [ -d "$ACTIVE_DIR" ] || fail "active directory not found: $ACTIVE_DIR"
  if [ "$mode" = "apply" ] && [ "$close_cmux" -eq 1 ] && ! cmux_available "$cmux_bin"; then
    fail "cmux executable not found: $cmux_bin"
  fi

  local inventory_file
  inventory_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$inventory_file'" RETURN

  local inventory_loaded=0
  if [ "$close_cmux" -eq 1 ] && load_cmux_inventory "$cmux_bin" "$inventory_file"; then
    inventory_loaded=1
  fi

  if [ "$mode" = "apply" ] && [ "$close_cmux" -eq 1 ] && [ "$inventory_loaded" -ne 1 ]; then
    fail "cannot read cmux workspace inventory for apply delete"
  fi

  local removed_links=0 planned_links=0 closed_workspaces=0 planned_workspaces=0 skipped=0
  local target name link workspace_name workspace_ref

  for target in "${targets[@]}"; do
    name="$(active_name_from_delete_arg "$target")"
    is_safe_name "$name" || fail "unsafe active name: $name"
    link="$ACTIVE_DIR/$name"
    workspace_name="${NAME_PREFIX}${name}"

    if [ -L "$link" ]; then
      if [ "$mode" = "apply" ]; then
        rm "$link"
        printf 'unlink\t%s\t%s\n' "$name" "$link"
        removed_links=$((removed_links + 1))
      else
        printf 'would-unlink\t%s\t%s\n' "$name" "$link"
        planned_links=$((planned_links + 1))
      fi
    elif [ -e "$link" ]; then
      printf 'skip not-symlink\t%s\t%s\n' "$name" "$link"
      skipped=$((skipped + 1))
    else
      printf 'skip missing-link\t%s\t%s\n' "$name" "$link"
      skipped=$((skipped + 1))
    fi

    if [ "$close_cmux" -eq 0 ]; then
      printf 'skip cmux-kept\t%s\n' "$workspace_name"
      skipped=$((skipped + 1))
      continue
    fi

    if [ "$inventory_loaded" -ne 1 ]; then
      printf 'skip cmux-unavailable\t%s\n' "$workspace_name"
      skipped=$((skipped + 1))
      continue
    fi

    if workspace_ref="$(workspace_ref_for_title "$inventory_file" "$workspace_name")"; then
      if [ "$mode" = "apply" ]; then
        "$cmux_bin" close-workspace --workspace "$workspace_ref" >/dev/null
        printf 'close-workspace\t%s\t%s\n' "$workspace_name" "$workspace_ref"
        closed_workspaces=$((closed_workspaces + 1))
      else
        printf 'would-close-workspace\t%s\t%s\n' "$workspace_name" "$workspace_ref"
        planned_workspaces=$((planned_workspaces + 1))
      fi
    else
      printf 'skip missing-workspace\t%s\n' "$workspace_name"
      skipped=$((skipped + 1))
    fi
  done

  printf 'summary\tmode=%s\tplanned_links=%s\tremoved_links=%s\tplanned_workspaces=%s\tclosed_workspaces=%s\tskipped=%s\n' \
    "$mode" "$planned_links" "$removed_links" "$planned_workspaces" "$closed_workspaces" "$skipped"
  if [ "$mode" = "dry-run" ]; then
    print_apply_hint delete "${targets[@]}"
  fi
}

cmd_sync() {
  local mode="dry-run"
  local direction="active-to-cmux"
  local cmux_bin
  cmux_bin="$(find_cmux)"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --direction)
        [ "$#" -ge 2 ] || fail "--direction requires a value"
        direction="$2"
        shift 2
        ;;
      --active-dir)
        [ "$#" -ge 2 ] || fail "--active-dir requires a path"
        ACTIVE_DIR="$2"
        shift 2
        ;;
      --cmux)
        [ "$#" -ge 2 ] || fail "--cmux requires a path"
        cmux_bin="$2"
        shift 2
        ;;
      --name-prefix)
        [ "$#" -ge 2 ] || fail "--name-prefix requires text"
        NAME_PREFIX="$2"
        shift 2
        ;;
      -h|--help)
        command_help sync
        exit 0
        ;;
      *)
        fail "unknown sync option: $1"
        ;;
    esac
  done

  case "$direction" in
    active-to-cmux|cmux-to-active|both) ;;
    *) fail "invalid direction: $direction" ;;
  esac

  [ -d "$ACTIVE_DIR" ] || fail "active directory not found: $ACTIVE_DIR"
  if [ "$mode" = "apply" ] && has_direction "$direction" active-to-cmux && ! cmux_available "$cmux_bin"; then
    fail "cmux executable not found: $cmux_bin"
  fi

  local inventory_file seen_targets
  inventory_file="$(mktemp)"
  seen_targets="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$inventory_file' '$seen_targets'" RETURN

  local inventory_loaded=0
  if load_cmux_inventory "$cmux_bin" "$inventory_file"; then
    inventory_loaded=1
  fi

  if [ "$mode" = "apply" ] && [ "$inventory_loaded" -ne 1 ]; then
    fail "cannot read cmux workspace inventory for apply sync"
  fi

  if has_direction "$direction" cmux-to-active && [ "$inventory_loaded" -ne 1 ]; then
    printf 'skip reverse-unavailable\tno-workspace-cwd\n'
  fi

  local created_workspaces=0 planned_workspaces=0 created_links=0 planned_links=0 skipped=0

  if has_direction "$direction" active-to-cmux; then
    shopt -s nullglob
    local link name workspace_name target
    for link in "$ACTIVE_DIR"/*; do
      if [ ! -L "$link" ]; then
        skipped=$((skipped + 1))
        continue
      fi

      name="$(basename "$link")"
      if ! is_safe_name "$name"; then
        printf 'skip unsafe-name\t%s\n' "$name"
        skipped=$((skipped + 1))
        continue
      fi
      workspace_name="${NAME_PREFIX}${name}"

      if ! target="$(resolve_dir "$link")"; then
        printf 'skip broken-or-non-dir\t%s\n' "$name"
        skipped=$((skipped + 1))
        continue
      fi

      if grep -Fx -- "$target" "$seen_targets" >/dev/null 2>&1; then
        printf 'skip duplicate-target\t%s\t%s\n' "$workspace_name" "$target"
        skipped=$((skipped + 1))
        continue
      fi
      printf '%s\n' "$target" >> "$seen_targets"

      if [ "$inventory_loaded" -eq 1 ] && workspace_title_exists "$inventory_file" "$workspace_name"; then
        printf 'skip existing\t%s\t%s\n' "$workspace_name" "$target"
        skipped=$((skipped + 1))
        continue
      fi

      if [ "$mode" = "apply" ]; then
        printf 'create-workspace\t%s\t%s\n' "$workspace_name" "$target"
        "$cmux_bin" new-workspace --name "$workspace_name" --cwd "$target" --focus false >/dev/null
        created_workspaces=$((created_workspaces + 1))
      else
        printf 'would-create-workspace\t%s\t%s\n' "$workspace_name" "$target"
        planned_workspaces=$((planned_workspaces + 1))
      fi
    done
    shopt -u nullglob
  fi

  if has_direction "$direction" cmux-to-active && [ "$inventory_loaded" -eq 1 ]; then
    local title cwd _workspace_ref active_name reverse_target link_path existing_target
    while IFS=$'\t' read -r title cwd _workspace_ref; do
      case "$title" in
        "$NAME_PREFIX"*) ;;
        *) continue ;;
      esac

      active_name="${title#"$NAME_PREFIX"}"
      if ! is_safe_name "$active_name"; then
        printf 'skip unsafe-name\t%s\n' "$title"
        skipped=$((skipped + 1))
        continue
      fi

      if ! reverse_target="$(resolve_dir "$cwd")"; then
        printf 'skip missing-cwd\t%s\t%s\n' "$title" "$cwd"
        skipped=$((skipped + 1))
        continue
      fi

      link_path="$ACTIVE_DIR/$active_name"
      if [ -L "$link_path" ]; then
        if existing_target="$(resolve_dir "$link_path")" && [ "$existing_target" = "$reverse_target" ]; then
          printf 'skip existing-link\t%s\t%s\n' "$title" "$reverse_target"
        else
          printf 'skip conflicting-link\t%s\t%s\n' "$title" "$link_path"
        fi
        skipped=$((skipped + 1))
        continue
      fi

      if [ -e "$link_path" ]; then
        printf 'skip path-exists\t%s\t%s\n' "$title" "$link_path"
        skipped=$((skipped + 1))
        continue
      fi

      if [ "$mode" = "apply" ]; then
        printf 'create-link\t%s\t%s\t%s\n' "$title" "$link_path" "$reverse_target"
        ln -s "$reverse_target" "$link_path"
        created_links=$((created_links + 1))
      else
        printf 'would-create-link\t%s\t%s\t%s\n' "$title" "$link_path" "$reverse_target"
        planned_links=$((planned_links + 1))
      fi
    done < "$inventory_file"
  fi

  printf 'summary\tmode=%s\tdirection=%s\tplanned_workspaces=%s\tcreated_workspaces=%s\tplanned_links=%s\tcreated_links=%s\tskipped=%s\n' \
    "$mode" "$direction" "$planned_workspaces" "$created_workspaces" "$planned_links" "$created_links" "$skipped"
  if [ "$mode" = "dry-run" ]; then
    print_apply_hint "${C4J_APPLY_HINT_COMMAND:-sync}"
  fi
}

cmd_reconcile() {
  cmd_sync --direction both "$@"
}

cmd_worktree_list() {
  local mode="table"
  local repo_path=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --repo)
        [ "$#" -ge 2 ] || fail "--repo requires a path"
        repo_path="$2"
        shift 2
        ;;
      --plain|--tsv)
        mode="plain"
        shift
        ;;
      -h|--help)
        command_help "worktree list"
        exit 0
        ;;
      *)
        fail "unknown worktree list option: $1"
        ;;
    esac
  done

  local scope_repo_root=""
  if [ -n "$repo_path" ]; then
    scope_repo_root="$(worktree_repo_root_for_path "$(resolve_dir "$repo_path")" 2>/dev/null)" || fail "git repo not found: $repo_path"
  else
    scope_repo_root="$(worktree_repo_root_from_cmux "$(find_cmux)" 2>/dev/null || true)"
  fi

  local rows_file
  rows_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$rows_file'" RETURN

  collect_worktree_rows "$rows_file" "$scope_repo_root"
  worktree_render_rows "$rows_file" "$mode"
}

cmd_worktree_prune() {
  local mode="apply"
  local repo_path=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --repo)
        [ "$#" -ge 2 ] || fail "--repo requires a path"
        repo_path="$2"
        shift 2
        ;;
      -h|--help)
        command_help "worktree prune"
        exit 0
        ;;
      *)
        fail "unknown worktree prune option: $1"
        ;;
    esac
  done

  local scope_repo_root=""
  if [ -n "$repo_path" ]; then
    scope_repo_root="$(worktree_repo_root_for_path "$(resolve_dir "$repo_path")" 2>/dev/null)" || fail "git repo not found: $repo_path"
  else
    scope_repo_root="$(worktree_repo_root_from_cmux "$(find_cmux)" 2>/dev/null || true)"
  fi

  local roots_file
  roots_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$roots_file'" RETURN

  if [ -n "$scope_repo_root" ]; then
    printf '%s\n' "$scope_repo_root" > "$roots_file"
  else
    discover_worktree_repo_roots "$roots_file"
  fi

  if [ ! -s "$roots_file" ]; then
    printf 'No managed worktree repos found.\n'
    return 0
  fi

  local pruned_repos=0 planned_repos=0 skipped=0 repo_root repo_name
  while IFS= read -r repo_root; do
    [ -n "$repo_root" ] || continue
    [ -d "$repo_root" ] || continue
    repo_name="$(basename "$repo_root")"

    if [ "$mode" = "dry-run" ]; then
      printf 'would-prune-worktree-repo\t%s\t%s\n' "$repo_name" "$repo_root"
      planned_repos=$((planned_repos + 1))
      continue
    fi

    git -C "$repo_root" worktree prune >/dev/null 2>&1 || fail "failed to prune worktrees for repo: $repo_root"
    printf 'prune-worktree-repo\t%s\t%s\n' "$repo_name" "$repo_root"
    pruned_repos=$((pruned_repos + 1))
  done < "$roots_file"

  printf 'summary\tmode=%s\tplanned_repos=%s\tpruned_repos=%s\tskipped=%s\n' \
    "$mode" "$planned_repos" "$pruned_repos" "$skipped"
  if [ "$mode" = "dry-run" ]; then
    print_apply_hint wt prune
  fi
}

cmd_worktree_move() {
  local mode="apply"
  local repo_path=""
  local source=""
  local destination=""
  local source_set=0
  local positional=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --repo)
        [ "$#" -ge 2 ] || fail "--repo requires a path"
        repo_path="$2"
        shift 2
        ;;
      --target)
        [ "$#" -ge 2 ] || fail "--target requires text"
        source="$2"
        source_set=1
        shift 2
        ;;
      --to|--destination)
        [ "$#" -ge 2 ] || fail "--to requires text"
        destination="$2"
        shift 2
        ;;
      -h|--help)
        command_help "worktree move"
        exit 0
        ;;
      --)
        shift
        while [ "$#" -gt 0 ]; do
          positional+=("$1")
          shift
        done
        ;;
      --*)
        fail "unknown worktree move option: $1"
        ;;
      *)
        positional+=("$1")
        shift
        ;;
    esac
  done

  case "${#positional[@]}" in
    0)
      ;;
    1)
      if [ "$source_set" -eq 0 ] && [ -z "$source" ]; then
        destination="${positional[0]}"
      elif [ -z "$destination" ]; then
        destination="${positional[0]}"
      else
        fail "worktree move accepts at most one destination"
      fi
      ;;
    2)
      if [ "$source_set" -eq 0 ] && [ -z "$source" ]; then
        source="${positional[0]}"
        source_set=1
      else
        fail "worktree move accepts at most one source and one destination"
      fi
      if [ -z "$destination" ]; then
        destination="${positional[1]}"
      else
        fail "worktree move accepts at most one destination"
      fi
      ;;
    *)
      fail "worktree move accepts at most one source and one destination"
      ;;
  esac

  if [ -z "$destination" ]; then
    fail "worktree move requires a destination"
  fi

  local scope_repo_root=""
  if [ -n "$repo_path" ]; then
    scope_repo_root="$(worktree_repo_root_for_path "$(resolve_dir "$repo_path")" 2>/dev/null)" || fail "git repo not found: $repo_path"
  else
    scope_repo_root="$(worktree_repo_root_from_cmux "$(find_cmux)" 2>/dev/null || true)"
    if [ -z "$scope_repo_root" ]; then
      scope_repo_root="$(worktree_repo_root_for_path "$PWD" 2>/dev/null || true)"
    fi
  fi

  if [ -z "$source" ]; then
    source="$(worktree_current_path_from_pwd 2>/dev/null || true)"
    [ -n "$source" ] || fail "worktree move requires a target or must be run inside a worktree"
  fi

  local rows_file matches_file match_count repo_root repo_name worktree_name worktree_path branch destination_path current_parent
  rows_file="$(mktemp)"
  matches_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$rows_file' '$matches_file'" RETURN

  collect_worktree_rows "$rows_file" "$scope_repo_root"
  worktree_find_rows "$rows_file" "$source" "$matches_file"

  match_count="$(wc -l < "$matches_file" | tr -d ' ')"
  [ "$match_count" -gt 0 ] || fail "worktree not found: $source"
  [ "$match_count" -eq 1 ] || fail "worktree target is ambiguous: $source"

  IFS=$'\t' read -r repo_root repo_name worktree_name worktree_path branch < "$matches_file"
  [ "$worktree_path" != "$repo_root" ] || fail "refusing to move the main repository checkout: $worktree_path"

  if ! destination_path="$(worktree_move_destination_path "$repo_root" "$destination" 2>/dev/null)"; then
    fail "invalid worktree destination: $destination"
  fi

  if [ "$destination_path" = "$worktree_path" ]; then
    if [ "$mode" = "dry-run" ]; then
      printf 'would-skip-worktree-move\t%s\t%s\n' "$worktree_name" "$worktree_path"
      print_apply_hint wt move "$worktree_name" "$destination"
      return 0
    fi
    printf 'skip-worktree-move\t%s\t%s\n' "$worktree_name" "$worktree_path"
    return 0
  fi

  if [ -e "$destination_path" ]; then
    fail "destination already exists: $destination_path"
  fi

  if [ "$mode" = "dry-run" ]; then
    printf 'would-move-worktree\t%s\t%s\t%s\t%s\n' "$worktree_name" "$worktree_path" "$destination_path" "$branch"
    print_apply_hint wt move "$worktree_name" "$destination"
    return 0
  fi

  current_parent="$(dirname "$destination_path")"
  mkdir -p "$current_parent"
  git -C "$repo_root" worktree move "$worktree_path" "$destination_path" >/dev/null 2>&1 || fail "failed to move worktree: $worktree_path -> $destination_path"
  printf '%s\t%s\t%s\t%s\t%s\n' "$C4J_ACTION_MOVE_WORKTREE" "$worktree_name" "$worktree_path" "$destination_path" "$branch"
}

cmd_update() {
  local mode="apply"
  local repo_url="${C4J_REPO_URL:-$DEFAULT_REPO_URL}"
  local install_dir="${C4J_INSTALL_DIR:-$HOME/.local/share/c4j}"
  local ref="${C4J_UPDATE_REF:-${C4J_REF:-}}"
  local allow_unsafe_source=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --ref)
        [ "$#" -ge 2 ] || fail "--ref requires text"
        ref="$2"
        shift 2
        ;;
      --repo-url)
        [ "$#" -ge 2 ] || fail "--repo-url requires text"
        repo_url="$2"
        shift 2
        ;;
      --install-dir)
        [ "$#" -ge 2 ] || fail "--install-dir requires a path"
        install_dir="$2"
        shift 2
        ;;
      --allow-unsafe-source)
        allow_unsafe_source=1
        shift
        ;;
      -h|--help)
        command_help update
        exit 0
        ;;
      --*)
        fail "unknown update option: $1"
        ;;
      *)
        fail "update takes no positional arguments"
        ;;
    esac
  done

  if [ -z "$ref" ]; then
    if [ "$repo_url" != "$DEFAULT_REPO_URL" ] && [ "$allow_unsafe_source" -ne 1 ]; then
      fail "unsafe source requires --allow-unsafe-source: repo-url $repo_url"
    fi
    ref="$(update_latest_release_ref "$repo_url")" || fail "cannot determine latest release ref from: $repo_url"
  fi
  validate_update_source_policy "$repo_url" "$ref" "$allow_unsafe_source"

  if [ -e "$install_dir" ] && [ ! -d "$install_dir/.git" ]; then
    fail "install dir exists and is not a git clone: $install_dir"
  fi

  if [ "$mode" = "dry-run" ]; then
    local target_commit current_commit already_current
    target_commit="$(update_remote_ref_commit "$repo_url" "$ref")" || target_commit=""
    [ -n "$target_commit" ] || fail "cannot resolve target commit for ref: $ref"
    current_commit=""
    if [ -d "$install_dir/.git" ]; then
      current_commit="$(git -C "$install_dir" rev-parse HEAD 2>/dev/null || true)"
    fi
    already_current="false"
    if [ -n "$current_commit" ] && [ "$current_commit" = "$target_commit" ]; then
      already_current="true"
    fi
    printf 'current-version\t%s\n' "$VERSION"
    printf 'target-ref\t%s\n' "$ref"
    printf 'target-commit\t%s\n' "$target_commit"
    printf 'already-current\t%s\n' "$already_current"
    printf 'would-update-source\t%s\t%s\n' "$install_dir" "$ref"
    printf 'would-install-bin\t%s\n' "${C4J_BIN_DIR:-$HOME/.local/bin}/c4j"
    print_apply_hint update
    return 0
  fi

  update_source_checkout "$install_dir" "$repo_url" "$ref" || fail "failed to update source checkout: $install_dir"
  local target_bin="${C4J_BIN_DIR:-$HOME/.local/bin}/c4j"
  mkdir -p "$(dirname "$target_bin")"
  install -m 0755 "$install_dir/bin/cmux4justn" "$target_bin" || fail "failed to install updated c4j: $target_bin"
  printf 'update-cli\t%s\t%s\n' "$ref" "$install_dir"
}

cmd_worktree_delete() {
  local mode="apply"
  local force=0
  local target=""
  local repo_path=""
  local target_set=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --force|--discard)
        force=1
        shift
        ;;
      --repo)
        [ "$#" -ge 2 ] || fail "--repo requires a path"
        repo_path="$2"
        shift 2
        ;;
      --target)
        [ "$#" -ge 2 ] || fail "--target requires text"
        target="$2"
        target_set=1
        shift 2
        ;;
      -h|--help)
        command_help "worktree delete"
        exit 0
        ;;
      --)
        shift
        while [ "$#" -gt 0 ]; do
          if [ "$target_set" -eq 1 ]; then
            fail "worktree delete accepts at most one target"
          fi
          target="$1"
          target_set=1
          shift
        done
        ;;
      --*)
        fail "unknown worktree delete option: $1"
        ;;
      *)
        if [ "$target_set" -eq 1 ]; then
          fail "worktree delete accepts at most one target"
        fi
        target="$1"
        target_set=1
        shift
        ;;
    esac
  done

  local scope_repo_root=""
  if [ -n "$repo_path" ]; then
    scope_repo_root="$(worktree_repo_root_for_path "$(resolve_dir "$repo_path")" 2>/dev/null)" || fail "git repo not found: $repo_path"
  else
    scope_repo_root="$(worktree_repo_root_from_cmux "$(find_cmux)" 2>/dev/null || true)"
    if [ -z "$scope_repo_root" ]; then
      scope_repo_root="$(worktree_repo_root_for_path "$PWD" 2>/dev/null || true)"
    fi
  fi

  if [ -z "$target" ]; then
    target="$(worktree_current_path_from_pwd 2>/dev/null || true)"
    [ -n "$target" ] || fail "worktree delete requires a target or must be run inside a worktree"
  fi

  local rows_file matches_file match_count repo_root repo_name worktree_name worktree_path branch worktree_root
  rows_file="$(mktemp)"
  matches_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$rows_file' '$matches_file'" RETURN

  collect_worktree_rows "$rows_file" "$scope_repo_root"
  worktree_find_rows "$rows_file" "$target" "$matches_file"

  match_count="$(wc -l < "$matches_file" | tr -d ' ')"
  [ "$match_count" -gt 0 ] || fail "worktree not found: $target"
  [ "$match_count" -eq 1 ] || fail "worktree target is ambiguous: $target"

  IFS=$'\t' read -r repo_root repo_name worktree_name worktree_path branch < "$matches_file"
  worktree_root="$worktree_path"

  if [ "$worktree_root" = "$repo_root" ]; then
    fail "refusing to delete the main repository checkout: $worktree_root"
  fi

  if [ "$mode" = "dry-run" ]; then
    printf 'would-delete-worktree\t%s\t%s\t%s\n' "$worktree_name" "$worktree_root" "$branch"
    print_apply_hint wt delete "$worktree_name"
    return 0
  fi

  if [ "$force" -ne 1 ] && [ -n "$(git -C "$worktree_root" status --porcelain 2>/dev/null)" ]; then
    fail "worktree has uncommitted or untracked changes; rerun with --force or --discard to remove: $worktree_root"
  fi

  if [ "$force" -eq 1 ]; then
    git -C "$repo_root" worktree remove --force "$worktree_root" >/dev/null 2>&1 || fail "failed to remove worktree: $worktree_root"
  else
    git -C "$repo_root" worktree remove "$worktree_root" >/dev/null 2>&1 || fail "failed to remove worktree: $worktree_root"
  fi
  printf 'delete-worktree\t%s\t%s\t%s\n' "$worktree_name" "$worktree_root" "$branch"
}

cmd_worktree_update() {
  local mode="apply"
  local target=""
  local repo_path=""
  local target_set=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --repo)
        [ "$#" -ge 2 ] || fail "--repo requires a path"
        repo_path="$2"
        shift 2
        ;;
      --target)
        [ "$#" -ge 2 ] || fail "--target requires text"
        target="$2"
        target_set=1
        shift 2
        ;;
      -h|--help)
        command_help "worktree update"
        exit 0
        ;;
      --)
        shift
        while [ "$#" -gt 0 ]; do
          if [ "$target_set" -eq 1 ]; then
            fail "worktree update accepts at most one target"
          fi
          target="$1"
          target_set=1
          shift
        done
        ;;
      --*)
        fail "unknown worktree update option: $1"
        ;;
      *)
        if [ "$target_set" -eq 1 ]; then
          fail "worktree update accepts at most one target"
        fi
        target="$1"
        target_set=1
        shift
        ;;
    esac
  done

  local scope_repo_root=""
  if [ -n "$repo_path" ]; then
    scope_repo_root="$(worktree_repo_root_for_path "$(resolve_dir "$repo_path")" 2>/dev/null)" || fail "git repo not found: $repo_path"
  else
    scope_repo_root="$(worktree_repo_root_from_cmux "$(find_cmux)" 2>/dev/null || true)"
    if [ -z "$scope_repo_root" ]; then
      scope_repo_root="$(worktree_repo_root_for_path "$PWD" 2>/dev/null || true)"
    fi
  fi

  if [ -z "$target" ]; then
    target="$(worktree_update_target_path "" 2>/dev/null || true)"
    [ -n "$target" ] || fail "worktree update requires a target or must be run inside a worktree"
  fi

  local rows_file matches_file match_count repo_root repo_name worktree_name worktree_path branch
  rows_file="$(mktemp)"
  matches_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$rows_file' '$matches_file'" RETURN

  collect_worktree_rows "$rows_file" "$scope_repo_root"
  worktree_find_rows "$rows_file" "$target" "$matches_file"

  match_count="$(wc -l < "$matches_file" | tr -d ' ')"
  [ "$match_count" -gt 0 ] || fail "worktree not found: $target"
  [ "$match_count" -eq 1 ] || fail "worktree target is ambiguous: $target"

  IFS=$'\t' read -r repo_root repo_name worktree_name worktree_path branch < "$matches_file"

  if [ "$worktree_path" = "$repo_root" ]; then
    if [ "$mode" = "dry-run" ]; then
      printf 'would-update-repo\t%s\t%s\n' "$repo_name" "$worktree_path"
      print_apply_hint wt update "$worktree_name"
      return 0
    fi
  fi

  if [ "$mode" = "dry-run" ]; then
    printf 'would-update-worktree\t%s\t%s\t%s\n' "$worktree_name" "$worktree_path" "$branch"
    print_apply_hint wt update "$worktree_name"
    return 0
  fi

  (
    cd "$worktree_path"
    git fetch --all --prune >/dev/null 2>&1 || fail "failed to fetch updates: $worktree_path"
    git pull --ff-only >/dev/null 2>&1 || fail "failed to update worktree: $worktree_path"
  )
  printf 'update-worktree\t%s\t%s\t%s\n' "$worktree_name" "$worktree_path" "$branch"
}

cmd_worktree_create() {
  local mode="apply"
  local repo_path=""
  local repo_set=0
  local requested_name=""
  local name_set=0

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --repo)
        [ "$#" -ge 2 ] || fail "--repo requires a path"
        repo_path="$2"
        repo_set=1
        shift 2
        ;;
      --name)
        [ "$#" -ge 2 ] || fail "--name requires text"
        requested_name="$2"
        name_set=1
        shift 2
        ;;
      -h|--help)
        command_help worktree
        exit 0
        ;;
      --)
        shift
        while [ "$#" -gt 0 ]; do
          if [ "$name_set" -eq 1 ]; then
            fail "worktree accepts at most one name"
          fi
          requested_name="$1"
          name_set=1
          shift
        done
        ;;
      --*)
        fail "unknown worktree option: $1"
        ;;
      *)
        if [ "$name_set" -eq 1 ]; then
          fail "worktree accepts at most one name"
        fi
        requested_name="$1"
        name_set=1
        shift
        ;;
    esac
  done

  if [ -z "$repo_path" ]; then
    repo_path="$PWD"
    if ! git -C "$repo_path" rev-parse --show-toplevel >/dev/null 2>&1; then
      local cmux_bin current_workspace_dir
      cmux_bin="$(find_cmux)"
      if current_workspace_dir="$(cmux_workspace_directory "$cmux_bin" 2>/dev/null || true)"; then
        if [ -n "$current_workspace_dir" ] && git -C "$current_workspace_dir" rev-parse --show-toplevel >/dev/null 2>&1; then
          repo_path="$current_workspace_dir"
        fi
      fi
    fi
  fi

  repo_path="$(resolve_dir "$repo_path")" || fail "git repo not found: $repo_path"

  local repo_root canonical_root repo_name current_ref repo_slug ref_slug base_name final_name worktree_base worktree_path branch_name start_point
  local worktree_exists=0
  repo_root="$(git -C "$repo_path" rev-parse --show-toplevel 2>/dev/null)" || fail "git repo not found: $repo_path"
  canonical_root="$(canonical_git_root "$repo_path")" || fail "cannot resolve canonical repo root: $repo_path"
  repo_name="$(basename "$canonical_root")"
  repo_slug="$(slugify_name "$repo_name")" || fail "invalid repo name: $repo_name"
  current_ref="$(current_git_ref "$repo_path")" || fail "cannot resolve current git ref: $repo_path"
  ref_slug="$(slugify_name "$current_ref")" || fail "invalid git ref: $current_ref"
  base_name="${repo_slug}-${ref_slug}"

  case "$canonical_root" in
    */Workspaces/repos/*)
      local repos_root relative_repo_path
      repos_root="${canonical_root%%/Workspaces/repos/*}/Workspaces/repos"
      relative_repo_path="${canonical_root#"$repos_root"/}"
      worktree_base="${repos_root%/repos}/worktrees/$relative_repo_path"
      ;;
    *)
      worktree_base="$WORKTREE_DIR/external/$repo_slug"
      ;;
  esac

  if [ "$name_set" -eq 1 ]; then
    final_name="$(slugify_name "$requested_name")" || fail "invalid worktree name: $requested_name"
  else
    final_name="$base_name"
    local suffix=2
    while :; do
      worktree_path="$worktree_base/$final_name"
      branch_name="worktree/$final_name"
      if worktree_registered_at_path "$repo_root" "$worktree_path" || [ -e "$worktree_path" ] || worktree_branch_in_use "$repo_root" "$branch_name" || git_branch_exists "$repo_root" "$branch_name"; then
        final_name="${base_name}-$suffix"
        suffix=$((suffix + 1))
        continue
      fi
      break
    done
  fi

  worktree_path="$worktree_base/$final_name"
  branch_name="worktree/$final_name"
  start_point="$current_ref"

  if worktree_registered_at_path "$repo_root" "$worktree_path"; then
    worktree_exists=1
  elif [ -e "$worktree_path" ]; then
    fail "worktree path already exists and is not a registered worktree: $worktree_path"
  fi

  if [ "$worktree_exists" -eq 0 ]; then
    if [ "$mode" = "apply" ]; then
      mkdir -p "$worktree_base"
      if worktree_branch_in_use "$repo_root" "$branch_name"; then
        fail "worktree branch is already in use: $branch_name"
      fi
      if git_branch_exists "$repo_root" "$branch_name"; then
        git -C "$repo_root" worktree add "$worktree_path" "$branch_name" >/dev/null 2>&1 || fail "failed to create worktree: $worktree_path"
      else
        git -C "$repo_root" worktree add -b "$branch_name" "$worktree_path" "$start_point" >/dev/null 2>&1 || fail "failed to create worktree: $worktree_path"
      fi
      local upstream_ref
      upstream_ref="$(git -C "$repo_root" rev-parse --abbrev-ref "$current_ref@{upstream}" 2>/dev/null || true)"
      if [ -n "$upstream_ref" ]; then
        git -C "$worktree_path" branch --set-upstream-to="$upstream_ref" "$branch_name" >/dev/null 2>&1 || true
      fi
      printf '%s\t%s\t%s\t%s\n' "$C4J_ACTION_CREATE_WORKTREE" "$final_name" "$worktree_path" "$branch_name"
    else
      printf 'would-create-worktree\t%s\t%s\t%s\n' "$final_name" "$worktree_path" "$branch_name"
    fi
  else
    if [ "$mode" = "apply" ]; then
      printf '%s\t%s\t%s\n' "$C4J_ACTION_REUSE_WORKTREE" "$final_name" "$worktree_path"
    else
      printf 'would-reuse-worktree\t%s\t%s\n' "$final_name" "$worktree_path"
    fi
  fi

  if [ "$mode" = "dry-run" ]; then
    local hint_args=()
    if [ "$repo_set" -eq 1 ]; then
      hint_args+=(--repo "$repo_path")
    fi
    if [ "$name_set" -eq 1 ]; then
      hint_args+=(--name "$requested_name")
    fi
    if [ "${#hint_args[@]}" -gt 0 ]; then
      print_apply_hint worktree "${hint_args[@]}"
    else
      print_apply_hint worktree
    fi
  fi
}

cmd_worktree() {
  local reserved=""
  local reserved_index=-1
  local seen_name=0
  local args=("$@")
  local index=0
  local arg

  while [ "$index" -lt "${#args[@]}" ]; do
    arg="${args[$index]}"
    case "$arg" in
      --dry-run|--apply|-h|--help)
        index=$((index + 1))
        ;;
      --repo|--target)
        index=$((index + 2))
        ;;
      --to|--destination)
        index=$((index + 2))
        ;;
      --name)
        seen_name=1
        index=$((index + 2))
        ;;
      --)
        index=$((index + 1))
        if [ "$index" -lt "${#args[@]}" ] && [ "$seen_name" -eq 0 ]; then
          reserved="${args[$index]}"
          reserved_index="$index"
        fi
        break
        ;;
      --*)
        index=$((index + 1))
        ;;
      *)
        if [ "$seen_name" -eq 0 ]; then
          reserved="$arg"
          reserved_index="$index"
        fi
        break
        ;;
    esac
  done

  local -a tail_args=()
  if [ "$reserved_index" -ge 0 ]; then
    tail_args=("${args[@]:$((reserved_index + 1))}")
  fi

  case "$reserved" in
    list|ls)
      if [ "${#tail_args[@]}" -gt 0 ]; then
        cmd_worktree_list "${tail_args[@]}"
      else
        cmd_worktree_list
      fi
      ;;
    prune)
      if [ "${#tail_args[@]}" -gt 0 ]; then
        cmd_worktree_prune "${tail_args[@]}"
      else
        cmd_worktree_prune
      fi
      ;;
    move)
      if [ "${#tail_args[@]}" -gt 0 ]; then
        cmd_worktree_move "${tail_args[@]}"
      else
        cmd_worktree_move
      fi
      ;;
    delete|remove|rm)
      if [ "${#tail_args[@]}" -gt 0 ]; then
        cmd_worktree_delete "${tail_args[@]}"
      else
        cmd_worktree_delete
      fi
      ;;
    update|refresh|up)
      if [ "${#tail_args[@]}" -gt 0 ]; then
        cmd_worktree_update "${tail_args[@]}"
      else
        cmd_worktree_update
      fi
      ;;
    "")
      cmd_worktree_create "$@"
      ;;
    *)
      cmd_worktree_create "$@"
      ;;
  esac
}

cmd_list() {
  local format="table"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --plain|--tsv)
        format="plain"
        shift
        ;;
      -h|--help)
        command_help list
        exit 0
        ;;
      *)
        fail "unknown list option: $1"
        ;;
    esac
  done

  [ -d "$ACTIVE_DIR" ] || fail "active directory not found: $ACTIVE_DIR"
  local rows_file
  rows_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$rows_file'" RETURN

  shopt -s nullglob
  local link target
  for link in "$ACTIVE_DIR"/*; do
    [ -L "$link" ] || continue
    if target="$(resolve_dir "$link")"; then
      printf '%s\t%s\n' "$(basename "$link")" "$target" >> "$rows_file"
    else
      printf '%s\t%s\n' "$(basename "$link")" "BROKEN" >> "$rows_file"
    fi
  done
  shopt -u nullglob

  sort -f "$rows_file" -o "$rows_file"

  if [ "$format" = "plain" ]; then
    cat "$rows_file"
    return
  fi

  if [ ! -s "$rows_file" ]; then
    printf 'No active projects.\n'
    return
  fi

  local name_width
  name_width="$(awk -F '\t' 'BEGIN { max = length("PROJECT") } { if (length($1) > max) max = length($1) } END { print max }' "$rows_file")"
  printf "%-${name_width}s  %s\n" "PROJECT" "PATH"
  printf "%-${name_width}s  %s\n" "$(printf '%*s' "$name_width" '' | tr ' ' '-')" "----"
  awk -F '\t' -v width="$name_width" '{ printf "%-" width "s  %s\n", $1, $2 }' "$rows_file"
}

cmd_doctor() {
  local cmux_bin
  cmux_bin="$(find_cmux)"
  local config_status active_status cmux_status
  config_status="missing"
  active_status="missing"
  cmux_status="missing"
  [ -f "$CONFIG_FILE" ] && config_status="ok"
  [ -d "$ACTIVE_DIR" ] && active_status="ok"
  cmux_available "$cmux_bin" && cmux_status="ok"
  tsv_row config_file "$CONFIG_FILE" "$config_status"
  tsv_row active_dir "$ACTIVE_DIR" "$active_status"
  tsv_row cmux_bin "$cmux_bin" "$cmux_status"
}

main() {
  local command="${1:-}"
  case "$command" in
    add)
      shift
      cmd_add "$@"
      ;;
    cd)
      shift
      cmd_cd "$@"
      ;;
    go)
      shift
      cmd_go "$@"
      ;;
    anchor)
      shift
      cmd_anchor "$@"
      ;;
    delete|remove|rm)
      shift
      cmd_delete "$@"
      ;;
    update)
      shift
      cmd_update "$@"
      ;;
    repair|reconcile)
      shift
      cmd_reconcile "$@"
      ;;
    worktree|wt|pane|make-pane)
      shift
      cmd_worktree "$@"
      ;;
    setup)
      shift
      cmd_setup "$@"
      ;;
    sync)
      shift
      cmd_sync "$@"
      ;;
    list)
      shift
      cmd_list "$@"
      ;;
    config)
      shift
      cmd_config "$@"
      ;;
    doctor)
      shift
      if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
        [ "$#" -eq 1 ] || fail "doctor --help takes no arguments"
        command_help doctor
        return
      fi
      [ "$#" -eq 0 ] || fail "doctor takes no arguments"
      cmd_doctor
      ;;
    version|--version|-v)
      printf '%s\n' "$VERSION"
      ;;
    help)
      shift
      if [ "$#" -eq 0 ]; then
        usage
      else
        command_help "$*"
      fi
      ;;
    -h|--help|"")
      usage
      ;;
    *)
      fail "unknown command: $command (try: c4j help)"
      ;;
  esac
}

main "$@"
