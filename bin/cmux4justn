#!/usr/bin/env bash
set -euo pipefail

VERSION="0.9.0"
DEFAULT_ACTIVE_DIR="${HOME:-/Users/justn}/.c4j/active"
CONFIG_FILE="${C4J_CONFIG:-${CMUX4JUSTN_CONFIG:-${HOME:-/Users/justn}/.c4j/config}}"

config_get_value() {
  local key="$1"
  [ -f "$CONFIG_FILE" ] || return 1
  awk -F '=' -v key="$key" '$1 == key { print substr($0, length(key) + 2); found = 1 } END { exit found ? 0 : 1 }' "$CONFIG_FILE"
}

CONFIG_ACTIVE_DIR="$(config_get_value active_dir 2>/dev/null || true)"
CONFIG_CMUX_BIN="$(config_get_value cmux_bin 2>/dev/null || true)"
CONFIG_NAME_PREFIX="$(config_get_value name_prefix 2>/dev/null || true)"

ACTIVE_DIR="${C4J_ACTIVE_DIR:-${CMUX4JUSTN_ACTIVE_DIR:-${ACTIVE_DIR:-${CONFIG_ACTIVE_DIR:-$DEFAULT_ACTIVE_DIR}}}}"
CMUX_BIN="${C4J_CMUX_BIN:-${CMUX4JUSTN_CMUX_BIN:-${CMUX_BIN:-${CONFIG_CMUX_BIN:-}}}}"
NAME_PREFIX="${C4J_NAME_PREFIX:-${CMUX4JUSTN_NAME_PREFIX:-${CONFIG_NAME_PREFIX:-@active/}}}"

usage() {
  cat <<'USAGE'
c4j v0.9.0 - tiny active-project <-> cmux sync

Usage:
  c4j add [--dry-run|--apply] <path>...
  c4j delete [--dry-run|--apply] [--keep-cmux] <name-or-path>...
  c4j import-now [--dry-run|--apply]
  c4j sync [--dry-run|--apply] [--direction active-to-cmux|cmux-to-active|both]
  c4j list [--plain]
  c4j config get
  c4j config set active-dir <path>
  c4j config set name-prefix <prefix>
  c4j config unset active-dir
  c4j config unset name-prefix
  c4j config path
  c4j doctor
  c4j version

Defaults:
  add  => --apply, then sync --direction both
  delete => --apply, remove active symlink and close matching cmux workspace
  import-now => --dry-run, import legacy now-i-work-in-* cmux workspaces
  sync => --dry-run --direction active-to-cmux

Environment:
  C4J_ACTIVE_DIR   default: ~/.c4j/active
  C4J_CMUX_BIN     default: cmux from PATH or /Applications/cmux.app/Contents/Resources/bin/cmux
  C4J_NAME_PREFIX  default: @active/
  C4J_CONFIG       default: ~/.c4j/config

Compatibility:
  bin/cmux4justn and CMUX4JUSTN_* environment variables still work.
USAGE
}

fail() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

resolve_dir() {
  local path="$1"
  [ -d "$path" ] || return 1
  (cd -- "$path" && pwd -P)
}

is_safe_name() {
  local name="$1"
  [ -n "$name" ] || return 1
  [ "$name" != "." ] || return 1
  [ "$name" != ".." ] || return 1
  case "$name" in
    */*|*..*) return 1 ;;
  esac
  return 0
}

find_cmux() {
  if [ -n "$CMUX_BIN" ]; then
    printf '%s\n' "$CMUX_BIN"
  elif command -v cmux >/dev/null 2>&1; then
    command -v cmux
  elif [ -x "/Applications/cmux.app/Contents/Resources/bin/cmux" ]; then
    printf '%s\n' "/Applications/cmux.app/Contents/Resources/bin/cmux"
  else
    printf '%s\n' "cmux"
  fi
}

cmux_available() {
  local cmux_bin="$1"
  command -v "$cmux_bin" >/dev/null 2>&1 || [ -x "$cmux_bin" ]
}

has_direction() {
  local direction="$1"
  local requested="$2"
  case "$direction:$requested" in
    active-to-cmux:active-to-cmux|both:active-to-cmux|cmux-to-active:cmux-to-active|both:cmux-to-active)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

load_cmux_inventory() {
  local cmux_bin="$1"
  local output_file="$2"
  : > "$output_file"

  cmux_available "$cmux_bin" || return 1

  local json
  json="$("$cmux_bin" --json list-workspaces 2>/dev/null)" || return 1

  local parsed_file
  parsed_file="$(mktemp)"

  if command -v python3 >/dev/null 2>&1; then
    if JSON_INPUT="$json" python3 - "$parsed_file" <<'PY'
import json
import os
import sys

output_path = sys.argv[1]
data = json.loads(os.environ["JSON_INPUT"])
with open(output_path, "w", encoding="utf-8") as handle:
    for workspace in data.get("workspaces", []):
        title = workspace.get("title")
        cwd = workspace.get("current_directory")
        ref = workspace.get("ref")
        if (
            isinstance(title, str)
            and isinstance(cwd, str)
            and isinstance(ref, str)
            and not any(ch in title for ch in "\t\r\n")
            and not any(ch in cwd for ch in "\t\r\n")
            and not any(ch in ref for ch in "\t\r\n")
        ):
            handle.write(f"{title}\t{cwd}\t{ref}\n")
PY
    then
      mv "$parsed_file" "$output_file"
      return 0
    fi
    rm -f "$parsed_file"
    return 1
  fi

  if command -v jq >/dev/null 2>&1; then
    if printf '%s\n' "$json" | jq -r '.workspaces[] | select(.title and .current_directory and .ref) | select((.title | test("[\\t\\r\\n]") | not) and (.current_directory | test("[\\t\\r\\n]") | not) and (.ref | test("[\\t\\r\\n]") | not)) | [.title, .current_directory, .ref] | @tsv' > "$parsed_file"; then
      mv "$parsed_file" "$output_file"
      return 0
    fi
    rm -f "$parsed_file"
    return 1
  fi

  rm -f "$parsed_file"

  return 1
}

workspace_title_exists() {
  local inventory_file="$1"
  local title="$2"
  awk -F '\t' -v title="$title" '$1 == title { found = 1 } END { exit found ? 0 : 1 }' "$inventory_file"
}

workspace_ref_for_title() {
  local inventory_file="$1"
  local title="$2"
  awk -F '\t' -v title="$title" '$1 == title { print $3; found = 1; exit } END { exit found ? 0 : 1 }' "$inventory_file"
}

print_apply_hint() {
  local command="$1"
  shift
  printf 'note\tdry-run\tapply with: c4j %s' "$command"
  if [ "$#" -gt 0 ]; then
    printf ' %s' "$@"
  fi
  printf ' --apply\n'
}

config_key_for_field() {
  case "$1" in
    active-dir|workspace-dir|workspace-file)
      printf 'active_dir\n'
      ;;
    cmux-bin)
      printf 'cmux_bin\n'
      ;;
    name-prefix|prefix|workspace-prefix)
      printf 'name_prefix\n'
      ;;
    *)
      return 1
      ;;
  esac
}

config_value_for_field() {
  local field="$1"
  local value="$2"
  case "$field" in
    active-dir|workspace-dir|workspace-file)
      resolve_dir "$value" || return 1
      ;;
    cmux-bin)
      printf '%s\n' "$value"
      ;;
    name-prefix|prefix|workspace-prefix)
      [ -n "$value" ] || return 1
      case "$value" in
        *$'\t'*|*$'\r'*|*$'\n'*) return 1 ;;
      esac
      printf '%s\n' "$value"
      ;;
    *)
      return 1
      ;;
  esac
}

config_write_value() {
  local key="$1"
  local value="$2"
  local dir tmp_file
  dir="$(dirname "$CONFIG_FILE")"
  mkdir -p "$dir"
  tmp_file="$(mktemp)"
  if [ -f "$CONFIG_FILE" ]; then
    awk -F '=' -v key="$key" '$1 != key { print }' "$CONFIG_FILE" > "$tmp_file"
  fi
  printf '%s=%s\n' "$key" "$value" >> "$tmp_file"
  mv "$tmp_file" "$CONFIG_FILE"
}

config_unset_value() {
  local key="$1"
  local tmp_file
  [ -f "$CONFIG_FILE" ] || return 0
  tmp_file="$(mktemp)"
  awk -F '=' -v key="$key" '$1 != key { print }' "$CONFIG_FILE" > "$tmp_file"
  mv "$tmp_file" "$CONFIG_FILE"
}

cmd_config() {
  local subcommand="${1:-}"
  case "$subcommand" in
    get|"")
      [ "$#" -le 1 ] || fail "config get takes no arguments"
      printf 'config_file\t%s\n' "$CONFIG_FILE"
      printf 'active_dir\t%s\n' "$ACTIVE_DIR"
      printf 'cmux_bin\t%s\n' "$(find_cmux)"
      printf 'name_prefix\t%s\n' "$NAME_PREFIX"
      ;;
    set)
      [ "$#" -eq 3 ] || fail "config set requires a field and value"
      local field="$2"
      local value="$3"
      local key resolved
      key="$(config_key_for_field "$field")" || fail "unknown config field: $field"
      resolved="$(config_value_for_field "$field" "$value")" || fail "invalid value for $field: $value"
      config_write_value "$key" "$resolved"
      printf 'set\t%s\t%s\n' "$key" "$resolved"
      ;;
    unset)
      [ "$#" -eq 2 ] || fail "config unset requires a field"
      local field="$2"
      local key
      key="$(config_key_for_field "$field")" || fail "unknown config field: $field"
      config_unset_value "$key"
      printf 'unset\t%s\n' "$key"
      ;;
    path)
      [ "$#" -eq 1 ] || fail "config path takes no arguments"
      printf '%s\n' "$CONFIG_FILE"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      fail "unknown config command: $subcommand"
      ;;
  esac
}

cmd_add() {
  local mode="apply"
  local paths=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --)
        shift
        while [ "$#" -gt 0 ]; do
          paths+=("$1")
          shift
        done
        ;;
      --*)
        fail "unknown add option: $1"
        ;;
      *)
        paths+=("$1")
        shift
        ;;
    esac
  done

  [ -d "$ACTIVE_DIR" ] || fail "active directory not found: $ACTIVE_DIR"

  if [ "${#paths[@]}" -eq 0 ]; then
    cmd_sync --direction both "--$mode"
    return
  fi

  local path target name link existing
  for path in "${paths[@]}"; do
    target="$(resolve_dir "$path")" || fail "not a directory: $path"
    name="$(basename "$target")"
    is_safe_name "$name" || fail "unsafe active name: $name"
    link="$ACTIVE_DIR/$name"

    if [ -L "$link" ]; then
      existing="$(resolve_dir "$link")" || fail "existing active link is broken: $link"
      if [ "$existing" = "$target" ]; then
        printf 'skip existing-link\t%s\t%s\n' "$name" "$target"
        continue
      fi
      fail "active link already points elsewhere: $link -> $existing"
    fi

    if [ -e "$link" ]; then
      fail "active path already exists and is not a symlink: $link"
    fi

    if [ "$mode" = "dry-run" ]; then
      printf 'would-link\t%s\t%s\n' "$link" "$target"
    else
      printf 'link\t%s\t%s\n' "$link" "$target"
      ln -s "$target" "$link"
    fi
  done

  cmd_sync --direction both "--$mode"
}

active_name_from_delete_arg() {
  local arg="$1"
  local target

  if target="$(resolve_dir "$arg" 2>/dev/null)"; then
    basename "$target"
    return 0
  fi

  case "$arg" in
    "$NAME_PREFIX"*)
      printf '%s\n' "${arg#"$NAME_PREFIX"}"
      ;;
    */*)
      fail "delete target is not an existing directory or active name: $arg"
      ;;
    *)
      printf '%s\n' "$arg"
      ;;
  esac
}

cmd_delete() {
  local mode="apply"
  local close_cmux=1
  local cmux_bin
  local targets=()
  cmux_bin="$(find_cmux)"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --keep-cmux)
        close_cmux=0
        shift
        ;;
      --active-dir)
        [ "$#" -ge 2 ] || fail "--active-dir requires a path"
        ACTIVE_DIR="$2"
        shift 2
        ;;
      --cmux)
        [ "$#" -ge 2 ] || fail "--cmux requires a path"
        cmux_bin="$2"
        shift 2
        ;;
      --name-prefix)
        [ "$#" -ge 2 ] || fail "--name-prefix requires text"
        NAME_PREFIX="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --)
        shift
        while [ "$#" -gt 0 ]; do
          targets+=("$1")
          shift
        done
        ;;
      --*)
        fail "unknown delete option: $1"
        ;;
      *)
        targets+=("$1")
        shift
        ;;
    esac
  done

  [ "${#targets[@]}" -gt 0 ] || fail "delete requires at least one name or path"
  [ -d "$ACTIVE_DIR" ] || fail "active directory not found: $ACTIVE_DIR"
  if [ "$mode" = "apply" ] && [ "$close_cmux" -eq 1 ] && ! cmux_available "$cmux_bin"; then
    fail "cmux executable not found: $cmux_bin"
  fi

  local inventory_file
  inventory_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$inventory_file'" RETURN

  local inventory_loaded=0
  if [ "$close_cmux" -eq 1 ] && load_cmux_inventory "$cmux_bin" "$inventory_file"; then
    inventory_loaded=1
  fi

  if [ "$mode" = "apply" ] && [ "$close_cmux" -eq 1 ] && [ "$inventory_loaded" -ne 1 ]; then
    fail "cannot read cmux workspace inventory for apply delete"
  fi

  local removed_links=0 planned_links=0 closed_workspaces=0 planned_workspaces=0 skipped=0
  local target name link workspace_name workspace_ref

  for target in "${targets[@]}"; do
    name="$(active_name_from_delete_arg "$target")"
    is_safe_name "$name" || fail "unsafe active name: $name"
    link="$ACTIVE_DIR/$name"
    workspace_name="${NAME_PREFIX}${name}"

    if [ -L "$link" ]; then
      if [ "$mode" = "apply" ]; then
        rm "$link"
        printf 'unlink\t%s\t%s\n' "$name" "$link"
        removed_links=$((removed_links + 1))
      else
        printf 'would-unlink\t%s\t%s\n' "$name" "$link"
        planned_links=$((planned_links + 1))
      fi
    elif [ -e "$link" ]; then
      printf 'skip not-symlink\t%s\t%s\n' "$name" "$link"
      skipped=$((skipped + 1))
    else
      printf 'skip missing-link\t%s\t%s\n' "$name" "$link"
      skipped=$((skipped + 1))
    fi

    if [ "$close_cmux" -eq 0 ]; then
      printf 'skip cmux-kept\t%s\n' "$workspace_name"
      skipped=$((skipped + 1))
      continue
    fi

    if [ "$inventory_loaded" -ne 1 ]; then
      printf 'skip cmux-unavailable\t%s\n' "$workspace_name"
      skipped=$((skipped + 1))
      continue
    fi

    if workspace_ref="$(workspace_ref_for_title "$inventory_file" "$workspace_name")"; then
      if [ "$mode" = "apply" ]; then
        "$cmux_bin" close-workspace --workspace "$workspace_ref" >/dev/null
        printf 'close-workspace\t%s\t%s\n' "$workspace_name" "$workspace_ref"
        closed_workspaces=$((closed_workspaces + 1))
      else
        printf 'would-close-workspace\t%s\t%s\n' "$workspace_name" "$workspace_ref"
        planned_workspaces=$((planned_workspaces + 1))
      fi
    else
      printf 'skip missing-workspace\t%s\n' "$workspace_name"
      skipped=$((skipped + 1))
    fi
  done

  printf 'summary\tmode=%s\tplanned_links=%s\tremoved_links=%s\tplanned_workspaces=%s\tclosed_workspaces=%s\tskipped=%s\n' \
    "$mode" "$planned_links" "$removed_links" "$planned_workspaces" "$closed_workspaces" "$skipped"
  if [ "$mode" = "dry-run" ]; then
    print_apply_hint delete "${targets[@]}"
  fi
}

cmd_import_now() {
  local mode="dry-run"
  local cmux_bin
  local legacy_prefix="now-i-work-in-"
  local previous_apply_hint="${C4J_APPLY_HINT_COMMAND:-}"
  cmux_bin="$(find_cmux)"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --active-dir)
        [ "$#" -ge 2 ] || fail "--active-dir requires a path"
        ACTIVE_DIR="$2"
        shift 2
        ;;
      --cmux)
        [ "$#" -ge 2 ] || fail "--cmux requires a path"
        cmux_bin="$2"
        shift 2
        ;;
      --legacy-prefix)
        [ "$#" -ge 2 ] || fail "--legacy-prefix requires text"
        legacy_prefix="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        fail "unknown import-now option: $1"
        ;;
    esac
  done

  C4J_APPLY_HINT_COMMAND="import-now" cmd_sync --direction cmux-to-active "--$mode" --name-prefix "$legacy_prefix" --cmux "$cmux_bin" --active-dir "$ACTIVE_DIR"
  if [ -n "$previous_apply_hint" ]; then
    C4J_APPLY_HINT_COMMAND="$previous_apply_hint"
  else
    unset C4J_APPLY_HINT_COMMAND
  fi
}

cmd_sync() {
  local mode="dry-run"
  local direction="active-to-cmux"
  local cmux_bin
  cmux_bin="$(find_cmux)"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run)
        mode="dry-run"
        shift
        ;;
      --apply)
        mode="apply"
        shift
        ;;
      --direction)
        [ "$#" -ge 2 ] || fail "--direction requires a value"
        direction="$2"
        shift 2
        ;;
      --active-dir)
        [ "$#" -ge 2 ] || fail "--active-dir requires a path"
        ACTIVE_DIR="$2"
        shift 2
        ;;
      --cmux)
        [ "$#" -ge 2 ] || fail "--cmux requires a path"
        cmux_bin="$2"
        shift 2
        ;;
      --name-prefix)
        [ "$#" -ge 2 ] || fail "--name-prefix requires text"
        NAME_PREFIX="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        fail "unknown sync option: $1"
        ;;
    esac
  done

  case "$direction" in
    active-to-cmux|cmux-to-active|both) ;;
    *) fail "invalid direction: $direction" ;;
  esac

  [ -d "$ACTIVE_DIR" ] || fail "active directory not found: $ACTIVE_DIR"
  if [ "$mode" = "apply" ] && has_direction "$direction" active-to-cmux && ! cmux_available "$cmux_bin"; then
    fail "cmux executable not found: $cmux_bin"
  fi

  local inventory_file seen_targets
  inventory_file="$(mktemp)"
  seen_targets="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$inventory_file' '$seen_targets'" RETURN

  local inventory_loaded=0
  if load_cmux_inventory "$cmux_bin" "$inventory_file"; then
    inventory_loaded=1
  fi

  if [ "$mode" = "apply" ] && [ "$inventory_loaded" -ne 1 ]; then
    fail "cannot read cmux workspace inventory for apply sync"
  fi

  if has_direction "$direction" cmux-to-active && [ "$inventory_loaded" -ne 1 ]; then
    printf 'skip reverse-unavailable\tno-workspace-cwd\n'
  fi

  local created_workspaces=0 planned_workspaces=0 created_links=0 planned_links=0 skipped=0

  if has_direction "$direction" active-to-cmux; then
    shopt -s nullglob
    local link name workspace_name target
    for link in "$ACTIVE_DIR"/*; do
      if [ ! -L "$link" ]; then
        skipped=$((skipped + 1))
        continue
      fi

      name="$(basename "$link")"
      if ! is_safe_name "$name"; then
        printf 'skip unsafe-name\t%s\n' "$name"
        skipped=$((skipped + 1))
        continue
      fi
      workspace_name="${NAME_PREFIX}${name}"

      if ! target="$(resolve_dir "$link")"; then
        printf 'skip broken-or-non-dir\t%s\n' "$name"
        skipped=$((skipped + 1))
        continue
      fi

      if grep -Fx -- "$target" "$seen_targets" >/dev/null 2>&1; then
        printf 'skip duplicate-target\t%s\t%s\n' "$workspace_name" "$target"
        skipped=$((skipped + 1))
        continue
      fi
      printf '%s\n' "$target" >> "$seen_targets"

      if [ "$inventory_loaded" -eq 1 ] && workspace_title_exists "$inventory_file" "$workspace_name"; then
        printf 'skip existing\t%s\t%s\n' "$workspace_name" "$target"
        skipped=$((skipped + 1))
        continue
      fi

      if [ "$mode" = "apply" ]; then
        printf 'create-workspace\t%s\t%s\n' "$workspace_name" "$target"
        "$cmux_bin" new-workspace --name "$workspace_name" --cwd "$target" --focus false >/dev/null
        created_workspaces=$((created_workspaces + 1))
      else
        printf 'would-create-workspace\t%s\t%s\n' "$workspace_name" "$target"
        planned_workspaces=$((planned_workspaces + 1))
      fi
    done
    shopt -u nullglob
  fi

  if has_direction "$direction" cmux-to-active && [ "$inventory_loaded" -eq 1 ]; then
    local title cwd _workspace_ref active_name reverse_target link_path existing_target
    while IFS=$'\t' read -r title cwd _workspace_ref; do
      case "$title" in
        "$NAME_PREFIX"*) ;;
        *) continue ;;
      esac

      active_name="${title#"$NAME_PREFIX"}"
      if ! is_safe_name "$active_name"; then
        printf 'skip unsafe-name\t%s\n' "$title"
        skipped=$((skipped + 1))
        continue
      fi

      if ! reverse_target="$(resolve_dir "$cwd")"; then
        printf 'skip missing-cwd\t%s\t%s\n' "$title" "$cwd"
        skipped=$((skipped + 1))
        continue
      fi

      link_path="$ACTIVE_DIR/$active_name"
      if [ -L "$link_path" ]; then
        if existing_target="$(resolve_dir "$link_path")" && [ "$existing_target" = "$reverse_target" ]; then
          printf 'skip existing-link\t%s\t%s\n' "$title" "$reverse_target"
        else
          printf 'skip conflicting-link\t%s\t%s\n' "$title" "$link_path"
        fi
        skipped=$((skipped + 1))
        continue
      fi

      if [ -e "$link_path" ]; then
        printf 'skip path-exists\t%s\t%s\n' "$title" "$link_path"
        skipped=$((skipped + 1))
        continue
      fi

      if [ "$mode" = "apply" ]; then
        printf 'create-link\t%s\t%s\t%s\n' "$title" "$link_path" "$reverse_target"
        ln -s "$reverse_target" "$link_path"
        created_links=$((created_links + 1))
      else
        printf 'would-create-link\t%s\t%s\t%s\n' "$title" "$link_path" "$reverse_target"
        planned_links=$((planned_links + 1))
      fi
    done < "$inventory_file"
  fi

  printf 'summary\tmode=%s\tdirection=%s\tplanned_workspaces=%s\tcreated_workspaces=%s\tplanned_links=%s\tcreated_links=%s\tskipped=%s\n' \
    "$mode" "$direction" "$planned_workspaces" "$created_workspaces" "$planned_links" "$created_links" "$skipped"
  if [ "$mode" = "dry-run" ]; then
    print_apply_hint "${C4J_APPLY_HINT_COMMAND:-sync}"
  fi
}

cmd_list() {
  local format="table"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --plain|--tsv)
        format="plain"
        shift
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        fail "unknown list option: $1"
        ;;
    esac
  done

  [ -d "$ACTIVE_DIR" ] || fail "active directory not found: $ACTIVE_DIR"
  local rows_file
  rows_file="$(mktemp)"
  # shellcheck disable=SC2064
  trap "rm -f '$rows_file'" RETURN

  shopt -s nullglob
  local link target
  for link in "$ACTIVE_DIR"/*; do
    [ -L "$link" ] || continue
    if target="$(resolve_dir "$link")"; then
      printf '%s\t%s\n' "$(basename "$link")" "$target" >> "$rows_file"
    else
      printf '%s\t%s\n' "$(basename "$link")" "BROKEN" >> "$rows_file"
    fi
  done
  shopt -u nullglob

  sort -f "$rows_file" -o "$rows_file"

  if [ "$format" = "plain" ]; then
    cat "$rows_file"
    return
  fi

  if [ ! -s "$rows_file" ]; then
    printf 'No active projects.\n'
    return
  fi

  local name_width
  name_width="$(awk -F '\t' 'BEGIN { max = length("PROJECT") } { if (length($1) > max) max = length($1) } END { print max }' "$rows_file")"
  printf "%-${name_width}s  %s\n" "PROJECT" "PATH"
  printf "%-${name_width}s  %s\n" "$(printf '%*s' "$name_width" '' | tr ' ' '-')" "----"
  awk -F '\t' -v width="$name_width" '{ printf "%-" width "s  %s\n", $1, $2 }' "$rows_file"
}

cmd_doctor() {
  local cmux_bin
  cmux_bin="$(find_cmux)"
  printf 'config_file\t%s\t' "$CONFIG_FILE"
  [ -f "$CONFIG_FILE" ] && printf 'ok\n' || printf 'missing\n'
  printf 'active_dir\t%s\t' "$ACTIVE_DIR"
  [ -d "$ACTIVE_DIR" ] && printf 'ok\n' || printf 'missing\n'
  printf 'cmux_bin\t%s\t' "$cmux_bin"
  cmux_available "$cmux_bin" && printf 'ok\n' || printf 'missing\n'
}

main() {
  local command="${1:-}"
  case "$command" in
    add)
      shift
      cmd_add "$@"
      ;;
    delete|remove|rm)
      shift
      cmd_delete "$@"
      ;;
    import-now)
      shift
      cmd_import_now "$@"
      ;;
    sync)
      shift
      cmd_sync "$@"
      ;;
    list)
      shift
      cmd_list "$@"
      ;;
    config)
      shift
      cmd_config "$@"
      ;;
    doctor)
      shift
      [ "$#" -eq 0 ] || fail "doctor takes no arguments"
      cmd_doctor
      ;;
    version|--version|-v)
      printf '%s\n' "$VERSION"
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      fail "unknown command: $command"
      ;;
  esac
}

main "$@"
